{
  "name": "documents-web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "PLAYWRIGHT_FORCE_TTY=1 playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:update-snapshots": "bash ./scripts/update-playwright-snapshots.sh",
    "test:update-snapshots:all": "PLAYWRIGHT_FORCE_TTY=1 playwright test --update-snapshots",
    "test:ui": "playwright test --ui",
    "test:lighthouse": "bash ./scripts/lighthouse.sh",
    "clean": "rm -rf dist .astro test-results playwright-report node_modules/.vite",
    "clean:deep": "rm -rf node_modules dist .astro test-results playwright-report && npm install",
    "format": "prettier . --write \"**/*.{js,ts,astro,md,json,css,scss,html}\"",
    "lint": "eslint . --ext .js,.ts,.astro",
    "lint-format": "bash ./scripts/lint-and-format.sh",
    "all": "bash ./scripts/all.sh"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "astro": "^6.1.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-astro": "^1.6.0",
    "lighthouse": "^13.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "vitest": "^4.1.3"
  }
}
