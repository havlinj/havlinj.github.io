# Copy to `.env.local` (ignored by git). Example token generation:
#   openssl rand -hex 24
#
# Dev: open any page with ?layoutDebug=1 (no token needed).
# Prod / preview build: same token must be baked in at build time, then use:
#   https://your-site.example/contact?layoutDebug=PASTE_TOKEN_HERE
#
# GitHub Pages: add repository secret PUBLIC_LAYOUT_DEBUG_TOKEN (same value).
PUBLIC_LAYOUT_DEBUG_TOKEN=
