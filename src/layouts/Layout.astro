---
import interLatin400Woff2 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import '../styles/global.css';
import '../styles/special-typography.css';
import '../styles/site-header.css';
import '../styles/footer.css';
import '../styles/page-buttons.css';
import profileStylesUrl from '../styles/profile.css?url';
import ProfileAppendStyles from '../components/layout/ProfileAppendStyles.astro';
import ProfileLayoutHead from '../components/layout/ProfileLayoutHead.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';

const {
  title,
  activeSection,
  showHeader = false,
  profileStylesLast = false,
} = Astro.props;
const pageTitle = title || 'Astro Basics';
const showSiteHeader = Boolean(activeSection || showHeader);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link
      rel="preload"
      href={interLatin400Woff2}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    {
      profileStylesLast && (
        <ProfileLayoutHead profileStylesUrl={profileStylesUrl} />
      )
    }
    <slot name="head" />
  </head>
  <body>
    {
      profileStylesLast && (
        <ProfileAppendStyles profileStylesUrl={profileStylesUrl} />
      )
    }
    <main class="content">
      {showSiteHeader && <SiteHeader activeSection={activeSection} />}
      <slot />
      <SiteFooter />
    </main>
    <script>
      import { initZoomGuard } from '../scripts/zoom-guard-init.ts';
      initZoomGuard();
    </script>
    <script>
      import '../scripts/layout-debug-overlay.ts';
    </script>
  </body>
</html>
