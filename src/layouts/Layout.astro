---
import interLatin400Woff2 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import '../styles/global.css';
import '../styles/special-typography.css';
import '../styles/writing.css';
import '../styles/site-header.css';
import '../styles/footer.css';
import '../styles/page-buttons.css';

const { title, activeSection, showHeader = false } = Astro.props;
const pageTitle = title || 'Astro Basics';
const navItems = [
  { href: '/profile', label: 'Profile', section: 'profile' },
  { href: '/writing', label: 'Writing', section: 'writing' },
  { href: '/contact', label: 'Contact', section: 'contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link
      rel="preload"
      href={interLatin400Woff2}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <slot name="head" />
  </head>
  <body>
    <main class="content">
      {
        (activeSection || showHeader) && (
          <header class="site-header">
            {/* No Home link: hero is welcome-only; main destinations are Profile / Writing / Contact. */}
            <div class="site-header__inner">
              {navItems.map((item) => (
                <a
                  href={item.href}
                  class={
                    'site-header__item site-nav__link' +
                    (activeSection === item.section
                      ? ' site-nav__link--active'
                      : '')
                  }
                >
                  {item.label}
                </a>
              ))}
            </div>
          </header>
        )
      }
      <slot />
      <footer class="site-footer">
        <div class="site-footer__inner">
          <a href="/" class="site-footer__link site-footer__home">Home</a>
          <a href="/credits" class="site-footer__link site-footer__credits">
            Credits
          </a>
          <p class="site-footer__copyright">© 2026 Jan Havlín</p>
        </div>
      </footer>
    </main>
    <script is:inline>
      (function () {
        'use strict';
        /* Profile: fade grid in only after portrait is ready AND tile type-fit JS ran
           (register type-fit listener synchronously — module may run before DOMContentLoaded). */

        var TYPE_FIT_FALLBACK_TIMEOUT_MS = 8000;
        var PORTRAIT_READY_TIMEOUT_MS = 4000;

        var section = document.querySelector('.profile-section--loading');
        if (!section) return;

        var portraitReady = false;
        var typeFitReady = false;

        function tryReveal() {
          if (!portraitReady || !typeFitReady) return;
          section.classList.remove('profile-section--loading');
        }

        function markTypeFitReady() {
          if (typeFitReady) return;
          typeFitReady = true;
          tryReveal();
        }

        document.addEventListener(
          'profileTileTypeFit',
          function onTypeFit() {
            markTypeFitReady();
          },
          { once: true },
        );

        setTimeout(function () {
          markTypeFitReady();
        }, TYPE_FIT_FALLBACK_TIMEOUT_MS);

        function wirePortrait() {
          var img = section.querySelector('.profile-photo-frame img');
          if (!img) {
            portraitReady = true;
            tryReveal();
            return;
          }
          var timeoutId;
          function reveal() {
            if (timeoutId) clearTimeout(timeoutId);
            img.removeEventListener('load', onReady);
            img.removeEventListener('error', reveal);
            portraitReady = true;
            tryReveal();
          }
          function onReady() {
            if (img.decode) {
              img.decode().then(reveal).catch(reveal);
            } else {
              reveal();
            }
          }
          if (img.complete && img.naturalWidth > 0) {
            onReady();
            return;
          }
          img.addEventListener('load', onReady);
          img.addEventListener('error', reveal);
          timeoutId = setTimeout(reveal, PORTRAIT_READY_TIMEOUT_MS);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', wirePortrait);
        } else {
          wirePortrait();
        }
      })();
    </script>
    <script is:inline>
      (function () {
        'use strict';

        var MAX_SAFE_ZOOM = 2.3;
        var ZOOM_EXIT_HYSTERESIS = 0.15;
        var FREEZE_SCALE_UPDATE_EPSILON = 0.01;
        var body = document.body;
        if (!body) return;

        // Text-only pages are excluded: guard is only for composition-heavy views.
        var hasComposition =
          !!document.querySelector('.hero') ||
          !!document.querySelector('.profile-section') ||
          !!document.querySelector('.writing-page .page-buttons-panel') ||
          !!document.querySelector('.contact-page .page-buttons-panel');
        if (!hasComposition) return;

        var BASELINE_KEY = 'zoomFreezeBaselineV2';
        var GUARD_STATE_KEY = 'zoomFreezeGuardStateV2';
        var WIDTH_DRIFT_RESET_RATIO = 0.22;
        var SCALE_DRIFT_EPSILON = 0.05;
        /* Reset when DPR jumps between sessions (e.g. desktop dpr=1 baseline vs phone dpr=3). */
        var DPR_BASELINE_MISMATCH_RATIO = 1.12;
        /* Stored innerWidth clearly desktop while current layout is phone-sized. */
        var DESKTOP_BASELINE_INNER_WIDTH_MIN = 640;
        var currentDpr = window.devicePixelRatio || 1;
        var currentVvScale =
          window.visualViewport && window.visualViewport.scale
            ? window.visualViewport.scale
            : 1;
        var currentInnerWidth = window.innerWidth || 0;
        var storedBaselineRaw = null;
        try {
          storedBaselineRaw = window.sessionStorage.getItem(BASELINE_KEY);
        } catch {}
        var storedBaseline = null;
        if (storedBaselineRaw) {
          try {
            storedBaseline = JSON.parse(storedBaselineRaw);
          } catch {
            storedBaseline = null;
          }
        }

        // If the user is currently in freeze-mode (persisted from before a reload),
        // keep the same baseline on reload. Baseline reset heuristics can be fooled
        // by the zoomed viewport (notably `innerWidth` shrinking), which then
        // makes the page render as if it were at the raw zoom (e.g. 400%).
        var storedGuardStateRawWarm = null;
        var persistedGuardActiveWarm = false;
        var persistedFreezeScaleWarm = 1;
        try {
          storedGuardStateRawWarm =
            window.sessionStorage.getItem(GUARD_STATE_KEY) ?? null;
        } catch {}
        if (storedGuardStateRawWarm) {
          try {
            var parsedWarm = JSON.parse(storedGuardStateRawWarm);
            if (parsedWarm && typeof parsedWarm.active === 'boolean') {
              persistedGuardActiveWarm = parsedWarm.active;
            }
            if (parsedWarm && Number.isFinite(parsedWarm.freezeScale)) {
              persistedFreezeScaleWarm = parsedWarm.freezeScale;
            }
          } catch {}
        }
        var shouldSkipBaselineResetWarm = persistedGuardActiveWarm === true;

        function hasValidBaseline(baseline) {
          return (
            baseline &&
            Number.isFinite(baseline.dpr) &&
            baseline.dpr > 0 &&
            Number.isFinite(baseline.vvScale) &&
            baseline.vvScale > 0 &&
            Number.isFinite(baseline.innerWidth) &&
            baseline.innerWidth > 0
          );
        }

        /** Same math as getZoomRatio below; inlined so we can validate before freeze UI applies. */
        function ratioFromBaseline(bd, bv, biw) {
          var vv = window.visualViewport;
          var vvScale = vv && vv.scale ? vv.scale : 0;
          var vvRatio = vvScale > 0 ? vvScale / bv : 1;
          var vvAbsoluteRatio = vvScale > 0 ? vvScale : 1;
          var dprRatio = (window.devicePixelRatio || 1) / bd;
          var cw = window.innerWidth || biw || 1;
          var innerWidthRatio =
            biw > 0 ? biw / Math.max(1, cw) : 1;
          return Math.max(vvRatio, vvAbsoluteRatio, dprRatio, innerWidthRatio);
        }

        function shouldResetBaseline(baseline) {
          if (!hasValidBaseline(baseline)) return true;

          var innerWidthNow = window.innerWidth || 0;
          var dprNow = window.devicePixelRatio || 1;
          var vvNow =
            window.visualViewport && window.visualViewport.scale
              ? window.visualViewport.scale
              : 1;

          // Hard resets for clearly different render contexts (device / orientation changes)
          var dprBaselineMismatch =
            Math.max(dprNow, baseline.dpr) / Math.min(dprNow, baseline.dpr) >
            DPR_BASELINE_MISMATCH_RATIO;

          // If effective zoom dropped well below the original baseline,
          // treat this as returning to a new "normal" neighborhood.
          var scaleDropped =
            dprNow < baseline.dpr * 0.9 || vvNow < baseline.vvScale * 0.9;

          // Only width *expansion* should force a new baseline. Width shrink
          // is often pure browser zoom — keep the original baseline so the
          // freeze threshold remains stable across pages at that zoom.
          var widthExpanded = innerWidthNow > baseline.innerWidth * 1.15;

          // Mobile safety: if baseline clearly desktop-sized but we are in a
          // very narrow viewport, discard it so freeze can re-derive from the
          // current narrow layout neighborhood.
          var likelyNarrowViewportZoomContext = innerWidthNow <= 520;
          var narrowButBaselineLooksDesktop =
            likelyNarrowViewportZoomContext &&
            baseline.innerWidth >= DESKTOP_BASELINE_INNER_WIDTH_MIN &&
            baseline.innerWidth > innerWidthNow * 1.25;

          return (
            dprBaselineMismatch ||
            scaleDropped ||
            widthExpanded ||
            narrowButBaselineLooksDesktop
          );
        }

        if (
          !hasValidBaseline(storedBaseline) ||
          (!shouldSkipBaselineResetWarm && shouldResetBaseline(storedBaseline))
        ) {
          storedBaseline = {
            dpr: currentDpr,
            vvScale: currentVvScale,
            innerWidth: currentInnerWidth,
          };
          try {
            window.sessionStorage.setItem(
              BASELINE_KEY,
              JSON.stringify({
                dpr: storedBaseline.dpr,
                vvScale: storedBaseline.vvScale,
                innerWidth: storedBaseline.innerWidth,
              }),
            );
          } catch {}
        }
        var baselineDpr = storedBaseline.dpr;
        var baselineVvScale = storedBaseline.vvScale;
        var baselineInnerWidth = storedBaseline.innerWidth;

        /*
         * Duplicated tab: sessionStorage is copied from the source tab, but this tab’s
         * zoom / layout metrics may differ (e.g. freeze-on at 400% vs new tab at 100%).
         * If persisted freeze does not match the real zoom ratio, drop persistence and
         * re-baseline from the current view before any paint logic runs in the loop.
         */
        var provisionalRatio = ratioFromBaseline(
          baselineDpr,
          baselineVvScale,
          baselineInnerWidth,
        );
        if (
          persistedGuardActiveWarm &&
          provisionalRatio <= MAX_SAFE_ZOOM - ZOOM_EXIT_HYSTERESIS
        ) {
          persistedGuardActiveWarm = false;
          persistedFreezeScaleWarm = 1;
          storedBaseline = {
            dpr: currentDpr,
            vvScale: currentVvScale,
            innerWidth: currentInnerWidth,
          };
          try {
            window.sessionStorage.setItem(
              BASELINE_KEY,
              JSON.stringify({
                dpr: storedBaseline.dpr,
                vvScale: storedBaseline.vvScale,
                innerWidth: storedBaseline.innerWidth,
              }),
            );
          } catch {}
          try {
            window.sessionStorage.removeItem(GUARD_STATE_KEY);
          } catch {}
          baselineDpr = storedBaseline.dpr;
          baselineVvScale = storedBaseline.vvScale;
          baselineInnerWidth = storedBaseline.innerWidth;
        }

        var mainContent = document.querySelector('main.content');
        var freezeActive = persistedGuardActiveWarm;
        var freezeScale = persistedFreezeScaleWarm;

        body.classList.toggle('zoom-threshold-exceeded', freezeActive);
        if (mainContent instanceof HTMLElement) {
          mainContent.style.setProperty(
            '--zoom-freeze-scale',
            String(freezeScale),
          );
          mainContent.classList.toggle('zoom-freeze-active', freezeActive);
        }

        function persistGuardState(nextActive, nextFreezeScale) {
          // SessionStorage writes are expensive; only persist on real changes.
          if (
            nextActive === lastPersistedActive &&
            Math.abs(nextFreezeScale - lastPersistedFreezeScale) <
              FREEZE_SCALE_UPDATE_EPSILON
          ) {
            return;
          }
          lastPersistedActive = nextActive;
          lastPersistedFreezeScale = nextFreezeScale;
          try {
            window.sessionStorage.setItem(
              GUARD_STATE_KEY,
              JSON.stringify({
                active: nextActive,
                freezeScale: nextFreezeScale,
                // helpful for future debugging; not used for decisions
                ts: Date.now(),
              }),
            );
          } catch {}
        }

        var lastPersistedActive = freezeActive;
        var lastPersistedFreezeScale = freezeScale;

        function getZoomRatio() {
          var vv = window.visualViewport;
          var vvScale = vv && vv.scale ? vv.scale : 0;
          var vvRatio = vvScale > 0 ? vvScale / baselineVvScale : 1;
          var vvAbsoluteRatio = vvScale > 0 ? vvScale : 1;
          var dprRatio = (window.devicePixelRatio || 1) / baselineDpr;
          var currentInnerWidth = window.innerWidth || baselineInnerWidth || 1;
          // IMPORTANT:
          // Keep this computation continuous.
          // The previous gating (innerWidthDrift > 0.03) makes the ratio jump
          // around the boundary zoom, so two pages can choose different freeze
          // states for the “same” pinch/browser zoom moment.
          var innerWidthRatio =
            baselineInnerWidth > 0
              ? baselineInnerWidth / Math.max(1, currentInnerWidth)
              : 1;

          return Math.max(vvRatio, vvAbsoluteRatio, dprRatio, innerWidthRatio);
        }

        function shouldKeepFreeze(ratio) {
          if (!freezeActive) return ratio > MAX_SAFE_ZOOM;
          return ratio > MAX_SAFE_ZOOM - ZOOM_EXIT_HYSTERESIS;
        }

        function updateZoomGuard() {
          var ratio = getZoomRatio();
          var exceeded = shouldKeepFreeze(ratio);
          if (exceeded) {
            var targetFreezeScale = Math.max(
              0.1,
              Math.min(1, MAX_SAFE_ZOOM / ratio),
            );
            if (
              !freezeActive ||
              Math.abs(targetFreezeScale - freezeScale) >=
                FREEZE_SCALE_UPDATE_EPSILON
            ) {
              // Quantize tiny scale fluctuations to avoid visible micro-jumps.
              freezeScale = Math.round(targetFreezeScale * 1000) / 1000;
            }
          } else {
            freezeScale = 1;
          }
          freezeActive = exceeded;
          persistGuardState(freezeActive, freezeScale);
          body.classList.toggle('zoom-threshold-exceeded', freezeActive);
          if (mainContent instanceof HTMLElement) {
            mainContent.style.setProperty(
              '--zoom-freeze-scale',
              String(freezeScale),
            );
            mainContent.classList.toggle('zoom-freeze-active', freezeActive);
          }
        }

        // Warm-start: only when freeze is still credible for this tab’s metrics
        // (reload / bfcache), not after we discarded stale duplicated-tab state.
        var ratioAfterReconcile = ratioFromBaseline(
          baselineDpr,
          baselineVvScale,
          baselineInnerWidth,
        );
        var warmStartDelayMs =
          freezeActive &&
          ratioAfterReconcile > MAX_SAFE_ZOOM - ZOOM_EXIT_HYSTERESIS
            ? 180
            : 0;
        var warmStartUntil = Date.now() + warmStartDelayMs;
        if (warmStartDelayMs === 0) {
          updateZoomGuard('init');
        }
        window.addEventListener(
          'resize',
          function () {
            updateZoomGuard();
          },
          { passive: true },
        );
        window.addEventListener(
          'orientationchange',
          function () {
            updateZoomGuard();
          },
          {
            passive: true,
          },
        );
        if (window.visualViewport) {
          window.visualViewport.addEventListener(
            'resize',
            function () {
              updateZoomGuard();
            },
            {
              passive: true,
            },
          );
          window.visualViewport.addEventListener(
            'scroll',
            function () {
              updateZoomGuard();
            },
            {
              passive: true,
            },
          );
        }
        function loopZoomGuard() {
          if (Date.now() >= warmStartUntil) {
            updateZoomGuard();
          }
          window.requestAnimationFrame(loopZoomGuard);
        }
        window.requestAnimationFrame(loopZoomGuard);
      })();
    </script>
    <script>
      import '../scripts/layout-debug-overlay.ts';
    </script>
  </body>
</html>
