---
import '../styles/global.css';
import '../styles/site-header.css';
import '../styles/page-buttons.css';

const { title, activeSection } = Astro.props;
const pageTitle = title || 'Astro Basics';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Fonts Inter -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <main class="content">
      {
        activeSection && (
          <header class="site-header">
            <div class="site-header__inner">
              <a href="/" class="site-header__item site-header__brand">
                Jan Havlín
              </a>
              <a
                href="/profile"
                class={
                  'site-header__item site-nav__link' +
                  (activeSection === 'profile' ? ' site-nav__link--active' : '')
                }
              >
                Profile
              </a>
              <a
                href="/writing"
                class={
                  'site-header__item site-nav__link' +
                  (activeSection === 'writing' ? ' site-nav__link--active' : '')
                }
              >
                Writing
              </a>
              <a
                href="/contact"
                class={
                  'site-header__item site-nav__link' +
                  (activeSection === 'contact' ? ' site-nav__link--active' : '')
                }
              >
                Contact
              </a>
            </div>
          </header>
        )
      }
      <slot />
    </main>
    <script is:inline>
      (function () {
        'use strict';
        /* Button dimensions from spec: width = BUTTON_WIDTH_FACTOR * textLength;
           overlay solid until GRADIENT_SOLID_UNTIL_RATIO * textLength, then fade to transparent by GRADIENT_TRANSPARENT_FROM_RATIO * textLength. */
        var BUTTON_WIDTH_FACTOR = 1.3;
        /* Fade starts earlier (more image visible); fade stretches past the word */
        var GRADIENT_SOLID_UNTIL_RATIO = 0.3;
        var GRADIENT_TRANSPARENT_FROM_RATIO = 1.28;
        var PARALLAX = { maxTranslate: 4, viewportRefWidth: 1200, horizontalFactor: 3, scale: 1.02 };

        function measureAndSizeButtons() {
          var buttons = document.querySelectorAll('.page-button');
          var offsetY = 0;
          buttons.forEach(function (btn) {
            var textEl = btn.querySelector('.page-button__text');
            var inner = btn.querySelector('.page-button__inner');
            if (!textEl || !inner) return;

            var textLengthPx = textEl.getBoundingClientRect().width;
            var paddingLeftPx = parseFloat(getComputedStyle(inner).paddingLeft) || 0;
            /* Base length + twice the text offset from the edge (both ends) so the rectangle is nicely long */
            var buttonWidthPx = Math.ceil(BUTTON_WIDTH_FACTOR * textLengthPx + 2 * paddingLeftPx);

            var gradientStartFadePercent = (GRADIENT_SOLID_UNTIL_RATIO / BUTTON_WIDTH_FACTOR) * 100;
            var gradientEndPercent = (GRADIENT_TRANSPARENT_FROM_RATIO / BUTTON_WIDTH_FACTOR) * 100;

            btn.style.setProperty('--btn-width', buttonWidthPx + 'px');
            btn.style.setProperty('--btn-gradient-start-fade', gradientStartFadePercent.toFixed(2));
            btn.style.setProperty('--btn-gradient-end', gradientEndPercent.toFixed(2));
            /* Each button shows the next vertical slice of the image (negative Y = image shifted up) */
            btn.style.setProperty('--page-button-bg-y', (-offsetY) + 'px');
            offsetY += btn.getBoundingClientRect().height;
          });
        }
        function initParallax() {
          document.querySelectorAll('.page-button').forEach(function (btn) {
            var bg = btn.querySelector('.page-button__bg');
            if (!bg) return;
            function update() {
              var rect = btn.getBoundingClientRect();
              var vh = window.innerHeight || document.documentElement.clientHeight;
              if (vh === 0) return;
              var raw = 1 - rect.top / vh;
              var clamped = Math.min(1, Math.max(0, raw));
              var scrollOffset = (clamped - 0.5) * 2 * PARALLAX.maxTranslate;
              var vw = window.innerWidth || document.documentElement.clientWidth;
              var horizontalOffset = (vw / PARALLAX.viewportRefWidth - 1) * PARALLAX.horizontalFactor;
              bg.style.transform = 'translate3d(' + horizontalOffset + 'px, ' + scrollOffset + 'px, 0) scale(' + PARALLAX.scale + ')';
            }
            update();
            window.addEventListener('scroll', update, { passive: true });
            window.addEventListener('resize', update);
          });
        }
        function wrapButtonChars() {
          document.querySelectorAll('.page-button').forEach(function (btn) {
            var textEl = btn.querySelector('.page-button__text');
            var glowEl = btn.querySelector('.page-button__glow');
            if (!textEl || !glowEl) return;
            var text = textEl.textContent || '';
            var chars = text.split('');
            if (chars.length === 0) return;
            var fragment = document.createDocumentFragment();
            chars.forEach(function (ch, i) {
              var span = document.createElement('span');
              span.className = 'page-button__char';
              span.style.setProperty('--char-index', String(i));
              span.textContent = ch;
              fragment.appendChild(span);
            });
            textEl.textContent = '';
            textEl.appendChild(fragment.cloneNode(true));
            glowEl.textContent = '';
            glowEl.appendChild(fragment);
          });
        }
        function initPageButtons() {
          if (!document.querySelector('.page-button')) return;
          measureAndSizeButtons();
          wrapButtonChars();
          initParallax();
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initPageButtons);
        } else {
          initPageButtons();
        }
        document.fonts && document.fonts.ready.then(measureAndSizeButtons);
      })();
    </script>
  </body>
</html>
