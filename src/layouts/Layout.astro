---
import '../styles/global.css';
import '../styles/writing.css';
import '../styles/site-header.css';
import '../styles/footer.css';
import '../styles/page-buttons.css';

const { title, activeSection } = Astro.props;
const pageTitle = title || 'Astro Basics';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Fonts Inter -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <main class="content">
      {
        activeSection && (
          <header class="site-header">
            <div class="site-header__inner">
              <a href="/" class="site-header__item site-header__brand">
                Jan Havlín
              </a>
              <a
                href="/profile"
                class={
                  'site-header__item site-nav__link' +
                  (activeSection === 'profile' ? ' site-nav__link--active' : '')
                }
              >
                Profile
              </a>
              <a
                href="/writing"
                class={
                  'site-header__item site-nav__link' +
                  (activeSection === 'writing' ? ' site-nav__link--active' : '')
                }
              >
                Writing
              </a>
              <a
                href="/contact"
                class={
                  'site-header__item site-nav__link' +
                  (activeSection === 'contact' ? ' site-nav__link--active' : '')
                }
              >
                Contact
              </a>
            </div>
          </header>
        )
      }
      <slot />
    </main>
    <footer class="site-footer">
      <p>© 2026 Jan Havlín</p>
      <a href="/credits" class="site-footer__credits">Credits</a>
    </footer>
    <script is:inline>
      (function () {
        'use strict';
        /* Buttons: solid page-bg only, no image/parallax/overlay gradient – no JS needed */

        function revealProfileSectionWhenPortraitLoaded() {
          var section = document.querySelector('.profile-section--loading');
          if (!section) return;
          var img = section.querySelector('.profile-photo-frame img');
          if (!img) {
            section.classList.remove('profile-section--loading');
            return;
          }
          var timeoutId;
          function reveal() {
            if (timeoutId) clearTimeout(timeoutId);
            img.removeEventListener('load', onReady);
            img.removeEventListener('error', reveal);
            section.classList.remove('profile-section--loading');
          }
          function onReady() {
            if (img.decode) {
              img.decode().then(reveal).catch(reveal);
            } else {
              reveal();
            }
          }
          if (img.complete && img.naturalWidth > 0) {
            onReady();
            return;
          }
          img.addEventListener('load', onReady);
          img.addEventListener('error', reveal);
          timeoutId = setTimeout(reveal, 4000);
        }
        if (document.readyState === 'loading') {
          document.addEventListener(
            'DOMContentLoaded',
            revealProfileSectionWhenPortraitLoaded,
          );
        } else {
          revealProfileSectionWhenPortraitLoaded();
        }
      })();
    </script>
  </body>
</html>
