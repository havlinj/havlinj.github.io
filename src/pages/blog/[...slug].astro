---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const dateFormatted = post.data.date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={post.data.title} activeSection="writing">
  <article class="blog-post">
    <h1>{post.data.title}</h1>
    <p class="article-meta" aria-label="Publication date">
      <time datetime={post.data.date.toISOString()}>{dateFormatted}</time>
    </p>
    <div class="article-body">
      <Content />
    </div>
  </article>
</Layout>
