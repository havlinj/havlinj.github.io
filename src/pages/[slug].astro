---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.id.replace(/\.md$/, '') },
    props: { page },
  }));
}

const { slug } = Astro.params;
const page = await getEntry('pages', slug);
if (!page) return Astro.redirect('/');
const { Content } = await page.render();

const profileSlugs = ['profile', 'intro', 'professional', 'personal'];
const activeSection = profileSlugs.includes(slug)
  ? 'profile'
  : slug === 'contact'
    ? 'contact'
    : undefined;
const isProfile = slug === 'profile';

const PROFILE_PRELOADS = [
  '/assets/hero/dichromatic_portrait_bayer_noise.png',
  '/assets/pages/profile/bg.jpg',
  '/assets/pages/profile/panel.jpg',
];

const profileArticleStyle = isProfile
  ? {
      '--page-button-bg': "url('/assets/pages/profile/bg.jpg')",
      '--page-button-bg-pos-x': '1%',
      '--page-button-bg-zoom': '0.12',
      '--page-button-bg-saturation': '3',
      '--page-button-bg-brightness': '1.4',
      '--page-button-bg-contrast': '1',
      '--panel-bg': "url('/assets/pages/profile/panel.jpg')",
      '--panel-bg-pos-x': '50%',
      '--panel-bg-pos-y': '50%',
      '--panel-bg-saturation': '0',
      '--panel-bg-brightness': '1',
      '--panel-bg-contrast': '1',
      '--panel-margin-top': '0',
      '--panel-padding-top': '2rem',
      '--panel-padding-left': '2rem',
      '--panel-padding-bottom': '2rem',
    }
  : undefined;
---

<Layout title={page.data.title} activeSection={activeSection}>
  {isProfile && PROFILE_PRELOADS.map((href) => (
    <link slot="head" rel="preload" as="image" href={href} />
  ))}
  <article class={isProfile ? 'has-buttons-panel' : undefined} style={profileArticleStyle}>
    <h1>{page.data.title}</h1>
    <Content />
  </article>
</Layout>
