---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.id.replace(/\.md$/, '') },
    props: { page },
  }));
}

const { slug } = Astro.params;
if (slug === 'credit') return Astro.redirect('/credits');
const page = await getEntry('pages', slug);
if (!page) return Astro.redirect('/');
const { Content } = await page.render();

const profileSlugs = ['profile', 'intro', 'professional', 'personal'];
const activeSection = profileSlugs.includes(slug)
  ? 'profile'
  : slug === 'contact'
    ? 'contact'
    : slug === 'credits'
      ? 'credits'
      : undefined;
const isProfile = slug === 'profile';
const isCredits = slug === 'credits';

const PROFILE_PRELOADS = [
  '/assets/hero/dichromatic_portrait_bayer_noise.png',
  '/assets/pages/profile/tai-bui-yKX7wC_VioM-unsplash_dichrom.png',
];
---

<Layout title={page.data.title} activeSection={activeSection}>
  {
    isProfile &&
      PROFILE_PRELOADS.map((href) => (
        <link slot="head" rel="preload" as="image" href={href} />
      ))
  }
  <article
    class={[isProfile && 'has-buttons-panel', isCredits && 'credits-page']
      .filter(Boolean)
      .join(' ')}
  >
    <h1
      class="page-title"
      style={isProfile ? { '--page-title-margin-bottom': '1.3rem' } : undefined}
    >
      {page.data.title}
    </h1>
    <Content />
  </article>
</Layout>
