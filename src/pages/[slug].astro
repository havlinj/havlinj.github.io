---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import WhyContent from '../components/WhyContent.astro';
import '../styles/profile.css';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.id.replace(/\.md$/, '') },
    props: { page },
  }));
}

const { slug } = Astro.params;
const page = await getEntry('pages', slug);
if (!page) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}
const { Content } = await render(page);

const PROFILE_SECTION_SLUGS = new Set([
  'profile',
  'why',
  'what-i-do',
  'foundations',
]);
const sectionBySlug: Record<string, string> = {
  contact: 'contact',
  credits: 'credits',
};
const activeSection = PROFILE_SECTION_SLUGS.has(slug)
  ? 'profile'
  : sectionBySlug[slug] || undefined;
const isProfile = slug === 'profile';
const isWhy = slug === 'why';
/** Same 1px rule under H1 as Contact (global.css --page-title-rule-gap) */
const hasPageTitleRule =
  slug === 'credits' || slug === 'what-i-do' || slug === 'foundations';

const PROFILE_PRELOADS = [
  '/assets/hero/dichromatic_portrait_bayer_noise.png',
  '/assets/pages/profile/tai-bui-yKX7wC_VioM-unsplash_dichrom.png',
];
---

<Layout title={page.data.title} activeSection={activeSection}>
  {
    isProfile &&
      PROFILE_PRELOADS.map((href) => (
        <link slot="head" rel="preload" as="image" href={href} />
      ))
  }
  <article
    class={[
      isProfile && 'has-buttons-panel',
      isWhy && 'why-page',
      hasPageTitleRule && 'has-page-title-rule',
    ]
      .filter(Boolean)
      .join(' ')}
  >
    <h1
      class="page-title"
      style={isProfile ? { '--page-title-margin-bottom': '1.3rem' } : undefined}
    >
      {page.data.title}
    </h1>
    {isWhy ? <WhyContent /> : <Content />}
  </article>
  {isProfile && <script>import '../scripts/profile-tile-type-fit.ts';</script>}
</Layout>
