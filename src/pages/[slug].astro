---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.id.replace(/\.md$/, '') },
    props: { page },
  }));
}

const { slug } = Astro.params;
if (slug === 'credit') return Astro.redirect('/credits');
const page = await getEntry('pages', slug);
if (!page) return Astro.redirect('/');
const { Content } = await render(page);

const profileSlugs = new Set(['profile', 'intro', 'professional', 'personal']);
const sectionBySlug: Record<string, string> = {
  contact: 'contact',
  credits: 'credits',
};
const activeSection = profileSlugs.has(slug)
  ? 'profile'
  : sectionBySlug[slug] || undefined;
const isProfile = slug === 'profile';
/** Same 1px rule under H1 as Contact (global.css --page-title-rule-gap) */
const hasPageTitleRule =
  slug === 'credits' ||
  slug === 'professional' ||
  slug === 'intro' ||
  slug === 'personal';

const PROFILE_PRELOADS = [
  '/assets/hero/dichromatic_portrait_bayer_noise.png',
  '/assets/pages/profile/tai-bui-yKX7wC_VioM-unsplash_dichrom.png',
];
---

<Layout title={page.data.title} activeSection={activeSection}>
  {
    isProfile &&
      PROFILE_PRELOADS.map((href) => (
        <link slot="head" rel="preload" as="image" href={href} />
      ))
  }
  <article
    class={[isProfile && 'has-buttons-panel', hasPageTitleRule && 'has-page-title-rule']
      .filter(Boolean)
      .join(' ')}
  >
    <h1
      class="page-title"
      style={isProfile ? { '--page-title-margin-bottom': '1.3rem' } : undefined}
    >
      {page.data.title}
    </h1>
    <Content />
  </article>
</Layout>
