---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import WhyContent from '../components/WhyContent.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter((page) => page.id.replace(/\.md$/, '') !== 'profile')
    .map((page) => ({
      params: { slug: page.id.replace(/\.md$/, '') },
      props: { page },
    }));
}

const { slug } = Astro.params;
const page = await getEntry('pages', slug);
if (!page) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}
const { Content } = await render(page);

const PROFILE_SECTION_SLUGS = new Set([
  'profile',
  'why-this',
  'what-i-do',
  'foundations',
]);
const sectionBySlug: Record<string, string> = {
  contact: 'contact',
  credits: 'credits',
};
const activeSection = PROFILE_SECTION_SLUGS.has(slug)
  ? 'profile'
  : sectionBySlug[slug] || undefined;
const isWhy = slug === 'why-this';
/** Same 1px rule under H1 as Contact (special-typography.css --page-title-rule-gap) */
const hasPageTitleRule =
  slug === 'credits' || slug === 'what-i-do' || slug === 'foundations';
---

<Layout title={page.data.title} activeSection={activeSection}>
  <article
    class={[isWhy && 'why-page', hasPageTitleRule && 'has-page-title-rule']
      .filter(Boolean)
      .join(' ')}
  >
    <h1 class="page-title">
      {page.data.title}
    </h1>
    {isWhy ? <WhyContent /> : <Content />}
  </article>
</Layout>
