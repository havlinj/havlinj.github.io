---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { splitAndSortWritingPosts } from '../utils/writing-posts';

const posts = await getCollection('blog');
const { featuredPosts, regularPosts } = splitAndSortWritingPosts(posts);

/**
 * Responsive Bayer PNGs (`*_720.png`, `*_1080.png`, …).
 *
 * The numeric suffix in the filename is NOT the bitmap width in pixels. It is the *intended
 * display width* (~CSS px) the asset was authored for. Files are oversampled (e.g. target × ~2.25)
 * so the browser downsamples a high-res Bayer grid → smoother pattern, less moiré.
 *
 * HTML `srcset` `w` descriptors MUST be each image’s *intrinsic pixel width* (what `identify`
 * reports). Do not use the filename number there — wrong descriptor breaks resource selection.
 *
 * Paths + intrinsic widths (must match files under `public/assets/pages/writing`).
 */
const writingBgStem =
  '/assets/pages/writing/weichao-deng-k0JQkPtfN3s-unsplash_dichrom';
const writingBgResponsive = {
  w720: { href: `${writingBgStem}_720.png`, w: 1620 },
  w1080: { href: `${writingBgStem}_1080.png`, w: 2160 },
  w1440: { href: `${writingBgStem}_1440.png`, w: 2736 },
  w1920: { href: `${writingBgStem}_1920.png`, w: 3360 },
  w2400: { href: `${writingBgStem}_2400.png`, w: 3840 },
} as const;

const defaultWritingBgOpacity = 0.94;
const defaultWritingBgNudgeX = 0;
const defaultWritingBgNudgeY = 0;

function toPanelBgPosition(value: number): string {
  return `calc(50% + ${value}px)`;
}

function formatWritingListDate(d: Date): string {
  return d.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: '2-digit',
  });
}
---

<Layout title="Writing" activeSection="writing">
  <article
    class="writing-page"
    style={{
      '--page-title-margin-bottom': '1.35rem',
      '--panel-bg-pos-x': toPanelBgPosition(defaultWritingBgNudgeX),
      '--panel-bg-pos-y': toPanelBgPosition(defaultWritingBgNudgeY),
      /* Softer pool photos over page wash (reverted from tile-only filter — read closer to intent). */
      '--panel-bg-layer-opacity': String(defaultWritingBgOpacity),
      /* Slightly below 1: pool shots often read loud on page wash; tune per asset if needed. */
      '--panel-bg-saturation': '0.97',
      '--panel-bg-brightness': '0.985',
      '--panel-bg-contrast': '0.97',
      // Gap under title: --page-title-margin-bottom above; optional extra: '--panel-margin-top': '0.5rem'
      '--panel-padding-top': '10%',
      '--panel-padding-left': '10%',
      '--panel-padding-bottom': '24%',
      '--writing-row-gap': '2cqi',
      '--writing-group-gap-mult': '3',
      '--writing-row-min-h': '5.8cqi',
      '--writing-row-max-h': '6.8cqi',
      '--writing-row-pad-block': '0.32cqi',
    }}
  >
    <h1 class="page-title">Writing</h1>
    <div class="page-buttons-zone">
      <div class="page-buttons-panel">
        <div class="page-buttons-panel__media" aria-hidden="true">
          <picture>
            <source
              media="(max-width: 767px)"
              srcset={`${writingBgResponsive.w720.href} ${writingBgResponsive.w720.w}w, ${writingBgResponsive.w1080.href} ${writingBgResponsive.w1080.w}w`}
              sizes="100vw"
            />
            <img
              src={writingBgResponsive.w1440.href}
              srcset={`${writingBgResponsive.w1080.href} ${writingBgResponsive.w1080.w}w, ${writingBgResponsive.w1440.href} ${writingBgResponsive.w1440.w}w, ${writingBgResponsive.w1920.href} ${writingBgResponsive.w1920.w}w, ${writingBgResponsive.w2400.href} ${writingBgResponsive.w2400.w}w`}
              sizes="100vw"
              width="2736"
              height="2204"
              alt=""
              decoding="async"
              fetchpriority="high"
            />
          </picture>
        </div>
        <div class="writing-groups writing-groups--pending" aria-busy="true">
          {
            featuredPosts.length > 0 && (
              <ul class="post-list page-buttons" aria-label="Featured articles">
                {featuredPosts.map((post) => (
                  <li>
                    <a href={`/blog/${post.id}`} class="page-button">
                      <span class="page-button__bg" aria-hidden="true" />
                      <span class="page-button__overlay" aria-hidden="true" />
                      <span class="page-button__inner">
                        <span class="page-button__glow-wrap" aria-hidden="true">
                          <span class="page-button__glow">
                            {post.data.title}
                          </span>
                        </span>
                        <span class="page-button__text">{post.data.title}</span>
                        <time
                          class="page-button__date"
                          datetime={post.data.date.toISOString()}
                        >
                          {formatWritingListDate(post.data.date)}
                        </time>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
          <ul class="post-list page-buttons" aria-label="Articles">
            {
              regularPosts.map((post) => (
                <li>
                  <a href={`/blog/${post.id}`} class="page-button">
                    <span class="page-button__bg" aria-hidden="true" />
                    <span class="page-button__overlay" aria-hidden="true" />
                    <span class="page-button__inner">
                      <span class="page-button__glow-wrap" aria-hidden="true">
                        <span class="page-button__glow">{post.data.title}</span>
                      </span>
                      <span class="page-button__text">{post.data.title}</span>
                      <time
                        class="page-button__date"
                        datetime={post.data.date.toISOString()}
                      >
                        {formatWritingListDate(post.data.date)}
                      </time>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </article>
  <noscript>
    <style>
      .writing-page .writing-groups.writing-groups--pending {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
    </style>
  </noscript>
  <script is:inline>
    (() => {
      const SELECTORS = {
        writingArticle: 'article.writing-page',
        writingGroups: '.writing-page .writing-groups',
      };
      const writingGroups = document.querySelector(SELECTORS.writingGroups);

      let buttonsRevealed = false;
      function revealWritingButtons() {
        if (buttonsRevealed || !writingGroups) return;
        buttonsRevealed = true;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            writingGroups.classList.remove('writing-groups--pending');
            writingGroups.classList.add('writing-groups--visible');
            writingGroups.removeAttribute('aria-busy');
          });
        });
      }

      const fontsReady = document.fonts?.ready ?? Promise.resolve();
      fontsReady.finally(() => revealWritingButtons());
      window.setTimeout(revealWritingButtons, 2500);
    })();
  </script>
</Layout>
