---
import { getCollection } from 'astro:content';
import { readdir } from 'node:fs/promises';
import { extname, join } from 'node:path';
import Layout from '../layouts/Layout.astro';
import { splitAndSortWritingPosts } from '../utils/writing-posts';

const posts = await getCollection('blog');
const { featuredPosts, regularPosts } = splitAndSortWritingPosts(posts);

const WRITING_POOL_DIR = join(
  process.cwd(),
  'public',
  'assets',
  'pages',
  'writing',
  'pool',
);
const IMAGE_EXTENSIONS = new Set([
  '.png',
  '.jpg',
  '.jpeg',
  '.webp',
  '.avif',
  '.gif',
  '.svg',
]);

let writingPoolUrls: string[] = [];
try {
  const dirEntries = await readdir(WRITING_POOL_DIR, { withFileTypes: true });
  writingPoolUrls = dirEntries
    .filter((entry) => entry.isFile())
    .map((entry) => entry.name)
    .filter((fileName: string) =>
      IMAGE_EXTENSIONS.has(extname(fileName).toLowerCase()),
    )
    .sort((a: string, b: string) => a.localeCompare(b, 'en'))
    .map(
      (fileName: string) =>
        `/assets/pages/writing/pool/${encodeURIComponent(fileName)}`,
    );
} catch {
  writingPoolUrls = [];
}
const defaultWritingBg = writingPoolUrls[0]
  ? `url('${writingPoolUrls[0]}')`
  : 'none';
---

<Layout title="Writing" activeSection="writing">
  <article
    class="writing-page"
    style={{
      '--page-title-margin-bottom': '1.35rem',
      '--panel-bg': defaultWritingBg,
      '--panel-bg-pos-x': '50%',
      '--panel-bg-pos-y': '50%',
      '--panel-bg-saturation': '1',
      '--panel-bg-brightness': '1',
      '--panel-bg-contrast': '1',
      // Gap under title: --page-title-margin-bottom above; optional extra: '--panel-margin-top': '0.5rem'
      '--panel-padding-top': '2rem',
      '--panel-padding-left': '2rem',
      '--panel-padding-bottom': '6rem',
    }}
  >
    <h1 class="page-title">Writing</h1>
    <div class="page-buttons-zone">
      <div class="page-buttons-panel">
        <div
          class="writing-groups writing-groups--pending"
          aria-busy="true"
        >
          {
            featuredPosts.length > 0 && (
              <ul class="post-list page-buttons" aria-label="Featured articles">
                {featuredPosts.map((post) => (
                  <li>
                    <a href={`/blog/${post.id}`} class="page-button">
                      <span class="page-button__bg" aria-hidden="true" />
                      <span class="page-button__overlay" aria-hidden="true" />
                      <span class="page-button__inner">
                        <span class="page-button__glow-wrap" aria-hidden="true">
                          <span class="page-button__glow">
                            {post.data.title}
                          </span>
                        </span>
                        <span class="page-button__text">{post.data.title}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
          <ul class="post-list page-buttons" aria-label="Articles">
            {
              regularPosts.map((post) => (
                <li>
                  <a href={`/blog/${post.id}`} class="page-button">
                    <span class="page-button__bg" aria-hidden="true" />
                    <span class="page-button__overlay" aria-hidden="true" />
                    <span class="page-button__inner">
                      <span class="page-button__glow-wrap" aria-hidden="true">
                        <span class="page-button__glow">{post.data.title}</span>
                      </span>
                      <span class="page-button__text">{post.data.title}</span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </article>
  <noscript>
    <style>
      .writing-page .writing-groups.writing-groups--pending {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
    </style>
  </noscript>
  <script is:inline define:vars={{ writingPoolUrls }}>
    (() => {
      const writingArticle = document.querySelector('article.writing-page');
      const writingGroups = document.querySelector(
        '.writing-page .writing-groups',
      );

      let buttonsRevealed = false;
      function revealWritingButtons() {
        if (buttonsRevealed || !writingGroups) return;
        buttonsRevealed = true;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            writingGroups.classList.remove('writing-groups--pending');
            writingGroups.classList.add('writing-groups--visible');
            writingGroups.removeAttribute('aria-busy');
          });
        });
      }

      const fontsReady = document.fonts?.ready ?? Promise.resolve();
      fontsReady.finally(() => revealWritingButtons());
      window.setTimeout(revealWritingButtons, 2500);

      if (!writingArticle) return;
      if (!Array.isArray(writingPoolUrls) || writingPoolUrls.length === 0)
        return;

      const storageKey = 'writing-bg-index';
      const currentIndex = readNonNegativeInt(
        window.localStorage.getItem(storageKey),
      );
      const selectedUrl =
        writingPoolUrls[currentIndex % writingPoolUrls.length];
      const nextIndex = (currentIndex + 1) % writingPoolUrls.length;

      window.localStorage.setItem(storageKey, String(nextIndex));
      writingArticle.style.setProperty('--panel-bg', `url('${selectedUrl}')`);

      function readNonNegativeInt(rawValue) {
        const parsed = Number.parseInt(rawValue ?? '0', 10);
        return Number.isFinite(parsed) && parsed >= 0 ? parsed : 0;
      }
    })();
  </script>
</Layout>
