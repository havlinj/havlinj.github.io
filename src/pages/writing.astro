---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { splitAndSortWritingPosts } from '../utils/writing-posts';
import {
  FALLBACK_WRITING_POOL_OPACITY,
  WRITING_POOL_ENTRIES,
  resolveWritingPoolEntry,
  toPanelBgPosition,
} from '../utils/writing-pool';

const posts = await getCollection('blog');
const { featuredPosts, regularPosts } = splitAndSortWritingPosts(posts);

const writingPoolEntries = WRITING_POOL_ENTRIES;
const defaultEntry = resolveWritingPoolEntry(writingPoolEntries[0]);
const defaultWritingBgUrl = defaultEntry?.url ?? 'none';
const defaultWritingBgOpacity =
  defaultEntry?.opacity ?? FALLBACK_WRITING_POOL_OPACITY;
const defaultWritingBgNudgeX = defaultEntry?.nudgeX ?? 0;
const defaultWritingBgNudgeY = defaultEntry?.nudgeY ?? 0;
const defaultWritingBg =
  defaultWritingBgUrl === 'none' ? 'none' : `url('${defaultWritingBgUrl}')`;

function formatWritingListDate(d: Date): string {
  return d.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: '2-digit',
  });
}
---

<Layout title="Writing" activeSection="writing">
  <article
    class="writing-page"
    style={{
      '--page-title-margin-bottom': '1.35rem',
      '--panel-bg': defaultWritingBg,
      '--panel-bg-pos-x': toPanelBgPosition(defaultWritingBgNudgeX),
      '--panel-bg-pos-y': toPanelBgPosition(defaultWritingBgNudgeY),
      /* Softer pool photos over page wash (reverted from tile-only filter — read closer to intent). */
      '--panel-bg-layer-opacity': String(defaultWritingBgOpacity),
      /* Slightly below 1: pool shots often read loud on page wash; tune per asset if needed. */
      '--panel-bg-saturation': '0.97',
      '--panel-bg-brightness': '0.985',
      '--panel-bg-contrast': '0.97',
      // Gap under title: --page-title-margin-bottom above; optional extra: '--panel-margin-top': '0.5rem'
      '--panel-padding-top': '10%',
      '--panel-padding-left': '10%',
      '--panel-padding-bottom': '24%',
      '--writing-row-gap': '2cqi',
      '--writing-group-gap-mult': '3',
      '--writing-row-min-h': '5.8cqi',
      '--writing-row-max-h': '6.8cqi',
      '--writing-row-pad-block': '0.32cqi',
    }}
  >
    <h1 class="page-title">Writing</h1>
    <div class="page-buttons-zone">
      <div class="page-buttons-panel">
        <div class="writing-groups writing-groups--pending" aria-busy="true">
          {
            featuredPosts.length > 0 && (
              <ul class="post-list page-buttons" aria-label="Featured articles">
                {featuredPosts.map((post) => (
                  <li>
                    <a href={`/blog/${post.id}`} class="page-button">
                      <span class="page-button__bg" aria-hidden="true" />
                      <span class="page-button__overlay" aria-hidden="true" />
                      <span class="page-button__inner">
                        <span class="page-button__glow-wrap" aria-hidden="true">
                          <span class="page-button__glow">
                            {post.data.title}
                          </span>
                        </span>
                        <span class="page-button__text">{post.data.title}</span>
                        <time
                          class="page-button__date"
                          datetime={post.data.date.toISOString()}
                        >
                          {formatWritingListDate(post.data.date)}
                        </time>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
          <ul class="post-list page-buttons" aria-label="Articles">
            {
              regularPosts.map((post) => (
                <li>
                  <a href={`/blog/${post.id}`} class="page-button">
                    <span class="page-button__bg" aria-hidden="true" />
                    <span class="page-button__overlay" aria-hidden="true" />
                    <span class="page-button__inner">
                      <span class="page-button__glow-wrap" aria-hidden="true">
                        <span class="page-button__glow">{post.data.title}</span>
                      </span>
                      <span class="page-button__text">{post.data.title}</span>
                      <time
                        class="page-button__date"
                        datetime={post.data.date.toISOString()}
                      >
                        {formatWritingListDate(post.data.date)}
                      </time>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </article>
  <noscript>
    <style>
      .writing-page .writing-groups.writing-groups--pending {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
    </style>
  </noscript>
  <script is:inline define:vars={{ writingPoolEntries }}>
    (() => {
      const SELECTORS = {
        writingArticle: 'article.writing-page',
        writingGroups: '.writing-page .writing-groups',
      };
      const STORAGE_KEY = 'writing-bg-index';
      const writingArticle = document.querySelector(SELECTORS.writingArticle);
      const writingGroups = document.querySelector(SELECTORS.writingGroups);

      let buttonsRevealed = false;
      function revealWritingButtons() {
        if (buttonsRevealed || !writingGroups) return;
        buttonsRevealed = true;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            writingGroups.classList.remove('writing-groups--pending');
            writingGroups.classList.add('writing-groups--visible');
            writingGroups.removeAttribute('aria-busy');
          });
        });
      }

      const fontsReady = document.fonts?.ready ?? Promise.resolve();
      fontsReady.finally(() => revealWritingButtons());
      window.setTimeout(revealWritingButtons, 2500);

      if (!writingArticle) return;
      if (!Array.isArray(writingPoolEntries) || writingPoolEntries.length === 0)
        return;

      const step = getWritingPoolStep(
        writingPoolEntries,
        window.localStorage.getItem(STORAGE_KEY),
      );
      if (!step) return;

      window.localStorage.setItem(STORAGE_KEY, String(step.nextIndex));
      writingArticle.style.setProperty(
        '--panel-bg',
        `url('${step.entry.url}')`,
      );
      writingArticle.style.setProperty(
        '--panel-bg-layer-opacity',
        String(step.entry.opacity),
      );
      writingArticle.style.setProperty(
        '--panel-bg-pos-x',
        toPanelBgPosition(step.entry.nudgeX),
      );
      writingArticle.style.setProperty(
        '--panel-bg-pos-y',
        toPanelBgPosition(step.entry.nudgeY),
      );

      function readNonNegativeInt(rawValue) {
        const parsed = Number.parseInt(rawValue ?? '0', 10);
        return Number.isFinite(parsed) && parsed >= 0 ? parsed : 0;
      }

      function getWritingPoolStep(entries, rawIndex) {
        if (!Array.isArray(entries) || entries.length === 0) return null;
        const currentIndex = readNonNegativeInt(rawIndex) % entries.length;
        const nextIndex = (currentIndex + 1) % entries.length;
        const entry = resolveWritingPoolEntry(entries[currentIndex]);
        if (!entry) return null;
        return { entry, currentIndex, nextIndex };
      }

      function resolveWritingPoolEntry(value) {
        if (!Array.isArray(value) || value.length < 4) return null;
        const [url, opacity, nudgeX, nudgeY] = value;
        if (typeof url !== 'string' || url.length === 0) return null;
        return {
          url,
          opacity: safeNumber(opacity, 0.94),
          nudgeX: safeNumber(nudgeX, 0),
          nudgeY: safeNumber(nudgeY, 0),
        };
      }

      function safeNumber(value, fallback) {
        const parsed = Number(value);
        return Number.isFinite(parsed) ? parsed : fallback;
      }

      function toPanelBgPosition(value) {
        return `calc(50% + ${value}px)`;
      }
    })();
  </script>
</Layout>
