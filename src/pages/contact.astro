---
import Layout from '../layouts/Layout.astro';
import ResponsiveDichromPicture from '../components/ResponsiveDichromPicture.astro';
import { buildDichromResponsive } from '../constants/dichrom-responsive';
import '../styles/contact.css';

const title = 'Contact — Jan Havlín';

const contactBg = buildDichromResponsive(
  '/assets/pages/contact/guillaume-didelet-ivuU1X9ULVk-unsplash_dichrom',
);
---

<Layout title={title} activeSection="contact">
  <article class="contact-page">
    <h1 class="page-title">Contact</h1>
    <div class="page-buttons-zone">
      <div class="page-buttons-panel">
        <div class="page-buttons-panel__media" aria-hidden="true">
          <ResponsiveDichromPicture
            sources={contactBg}
            width={2736}
            height={4104}
            fetchpriority="high"
          />
        </div>
        <div
          class="contact-page__fit-content contact-page__fit-content--pending"
          aria-busy="true"
        >
          <div class="contact-page__inset-rect contact-page__inset-rect--intro">
            <p class="contact-page__intro contact-page__intro--lead">
              Glad you made it this far.
            </p>
            <p class="contact-page__intro contact-page__intro--deck">
              If we think alike, there’s probably something worth building
              together.{' '}
              <span class="contact-page__intro-reach">Reach out.</span>
            </p>
          </div>
          <div class="contact-page__inset-rect contact-page__inset-rect--links">
            <nav class="contact-page__links" aria-label="Contact and profiles">
              <a href="/contact/form" class="contact-extra-link">
                <img
                  class="contact-extra-link__icon contact-extra-link__icon--bubble"
                  src="/assets/pages/contact/bubble.png"
                  alt=""
                  loading="eager"
                  decoding="async"
                />
                <span class="contact-extra-link__text">Message</span>
              </a>
              <a
                class="contact-extra-link"
                href="https://github.com/havlinj"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  class="contact-extra-link__icon"
                  src="/assets/pages/contact/github.svg"
                  alt=""
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
                />
                <span class="contact-extra-link__text">GitHub</span>
              </a>
              <a
                class="contact-extra-link"
                href="https://www.linkedin.com/in/jan-havlin"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  class="contact-extra-link__icon"
                  src="/assets/pages/contact/InBug-Black.png"
                  alt=""
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
                />
                <span class="contact-extra-link__text">LinkedIn</span>
              </a>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </article>

  <noscript>
    <style>
      .contact-page
        .contact-page__fit-content.contact-page__fit-content--pending {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
    </style>
  </noscript>

  <script>
    import '../scripts/contact-layout-fit.ts';
  </script>
</Layout>
