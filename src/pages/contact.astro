---
import Layout from '../layouts/Layout.astro';
import '../styles/contact.css';

const title = 'Contact — Jan Havlín';
---

<Layout title={title} activeSection="contact">
  <Fragment slot="head">
    <script
      is:inline
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer></script>
  </Fragment>
  <article class="contact">
    <h1>Contact</h1>
    <p class="contact-intro">Glad you stopped by.</p>
    <p class="contact-intro">
      Feel free to reach out about engineering, architecture, or opportunities.
    </p>

    <form id="contact-form" class="contact-form" novalidate>
      <label>
        Name
        <input type="text" name="name" maxlength="100" required />
      </label>

      <label>
        Email
        <input type="email" name="email" required />
      </label>

      <label>
        Message
        <textarea name="message" minlength="10" maxlength="5000" required
        ></textarea>
      </label>

      <div class="hidden" aria-hidden="true">
        <label>
          Company
          <input type="text" name="company" tabindex="-1" autocomplete="off" />
        </label>
      </div>

      <div class="cf-turnstile" data-sitekey="0x4AAAAAACpJlpuMEv-nLyuB"></div>

      <div class="contact-form__actions">
        <button type="submit">Send</button>
        <p id="status" class="contact-status" role="status" aria-live="polite">
        </p>
      </div>
    </form>
  </article>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const status = document.getElementById('status');

    if (form && status) {
      // Build profile URLs from segmented parts to avoid plain static href strings.
      const assembleUrl = (parts) => parts.join('');
      const githubUrl = assembleUrl([
        'https',
        '://',
        'github',
        '.com',
        '/',
        'havlinj',
      ]);
      const linkedInUrl = assembleUrl([
        'https',
        '://',
        'www',
        '.',
        'linkedin',
        '.com',
        '/',
        'in',
        '/',
        'jan-havlin',
      ]);

      // Insert 2 additional organization links right after the Send button.
      const sendButton = form.querySelector('button[type="submit"]');
      const actionsRow = form.querySelector('.contact-form__actions');
      if (
        sendButton &&
        actionsRow instanceof HTMLElement &&
        !form.querySelector('.contact-extra-links-wrapper')
      ) {
        const extraLinks = [
          {
            href: githubUrl,
            iconSrc: '/assets/pages/contact/github.svg',
            iconAlt: 'GitHub',
            label: 'GitHub',
          },
          {
            href: linkedInUrl,
            iconSrc: '/assets/pages/contact/InBug-Black.png',
            iconAlt: 'LinkedIn',
            label: 'LinkedIn',
          },
        ];

        const wrapper = document.createElement('div');
        wrapper.className = 'contact-extra-links-wrapper';

        const intro = document.createElement('p');
        intro.className = 'contact-extra-links-intro';
        intro.textContent = 'You can also find me on:';

        const container = document.createElement('div');
        container.className = 'contact-extra-links';
        container.setAttribute('aria-label', 'Additional links');

        extraLinks.forEach(({ href, iconSrc, iconAlt, label }) => {
          const a = document.createElement('a');
          a.className = 'contact-extra-link';
          a.href = href;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';

          const img = document.createElement('img');
          img.className = 'contact-extra-link__icon';
          img.src = iconSrc;
          img.alt = iconAlt;
          img.loading = 'lazy';

          const text = document.createElement('span');
          text.className = 'contact-extra-link__text';
          text.textContent = label;

          a.appendChild(img);
          a.appendChild(text);
          container.appendChild(a);
        });

        wrapper.appendChild(intro);
        wrapper.appendChild(container);
        actionsRow.insertAdjacentElement('afterend', wrapper);
      }

      /** New DOM nodes so the browser does not re-apply autofill to the same elements. */
      function replaceContactFieldsWithFreshElements() {
        const names = ['name', 'email', 'message', 'company'];
        for (const fieldName of names) {
          const oldEl = form.querySelector('[name="' + fieldName + '"]');
          if (!oldEl) continue;
          const tag = oldEl.tagName.toLowerCase();
          if (tag !== 'input' && tag !== 'textarea') continue;
          const fresh = document.createElement(tag);
          for (let i = 0; i < oldEl.attributes.length; i++) {
            const a = oldEl.attributes[i];
            fresh.setAttribute(a.name, a.value);
          }
          oldEl.replaceWith(fresh);
        }
      }

      let isSubmitting = false;
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (isSubmitting) return;
        isSubmitting = true;
        if (sendButton) sendButton.disabled = true;

        status.textContent = 'Sending...';

        const formData = new FormData(form);

        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            body: formData,
          });

          const data = await response.json();

          if (data.ok) {
            status.textContent = 'Thanks! Your message has been sent.';
            if (window.turnstile) {
              window.turnstile.reset();
            }
            replaceContactFieldsWithFreshElements();
          } else {
            status.textContent = data.error || 'Something went wrong.';

            if (window.turnstile && data.resetTurnstile) {
              window.turnstile.reset();
            }
          }
        } catch {
          status.textContent = 'Network error. Please try again.';

          if (window.turnstile) {
            window.turnstile.reset();
          }
        } finally {
          isSubmitting = false;
          if (sendButton) sendButton.disabled = false;
        }
      });
    }
  </script>
</Layout>
