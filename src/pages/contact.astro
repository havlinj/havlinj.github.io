---
import Layout from '../layouts/Layout.astro';
import '../styles/contact.css';

const title = 'Contact — Jan Havlín';

const contactBgStem =
  '/assets/pages/contact/guillaume-didelet-ivuU1X9ULVk-unsplash_dichrom';
const contactBgResponsive = {
  w720: { href: `${contactBgStem}_720.png`, w: 1620 },
  w1080: { href: `${contactBgStem}_1080.png`, w: 2160 },
  w1440: { href: `${contactBgStem}_1440.png`, w: 2736 },
  w1920: { href: `${contactBgStem}_1920.png`, w: 3360 },
  w2400: { href: `${contactBgStem}_2400.png`, w: 3840 },
} as const;
---

<Layout title={title} activeSection="contact">
  <article
    class="contact-page"
    style={{
      '--page-title-margin-bottom': '1.35rem',
      '--panel-bg-pos-x': '50%',
      '--panel-bg-pos-y': '50%',
      '--panel-bg-layer-opacity': '0.8',
      '--panel-bg-saturation': '0.97',
      '--panel-bg-brightness': '1',
      '--panel-bg-contrast': '0.97',
      '--panel-bg-zoom': '1.1',
      '--panel-bg-nudge-x': '0',
      '--panel-bg-nudge-y': '0.2',
      '--panel-padding-top': '10%',
      '--panel-padding-left': '10%',
      '--panel-padding-bottom': '24%',
      '--writing-row-gap': 'var(--panel-row-gap)',
      '--contact-link-row-min-h': 'var(--panel-row-min-h)',
      '--contact-link-row-max-h': 'var(--panel-row-max-h)',
      '--contact-link-row-gap': 'var(--panel-row-gap)',
      '--contact-link-pad-inline': '0.95em',
      '--contact-link-tail-pad': '1.5em',
      '--contact-link-pad-block': '0.46em',
    }}
  >
    <h1 class="page-title">Contact</h1>
    <div class="page-buttons-zone">
      <div class="page-buttons-panel">
        <div class="page-buttons-panel__media" aria-hidden="true">
          <picture>
            <source
              media="(max-width: 767px)"
              srcset={`${contactBgResponsive.w720.href} ${contactBgResponsive.w720.w}w, ${contactBgResponsive.w1080.href} ${contactBgResponsive.w1080.w}w`}
              sizes="100vw"
            />
            <img
              src={contactBgResponsive.w1440.href}
              srcset={`${contactBgResponsive.w1080.href} ${contactBgResponsive.w1080.w}w, ${contactBgResponsive.w1440.href} ${contactBgResponsive.w1440.w}w, ${contactBgResponsive.w1920.href} ${contactBgResponsive.w1920.w}w, ${contactBgResponsive.w2400.href} ${contactBgResponsive.w2400.w}w`}
              sizes="100vw"
              width="2736"
              height="4104"
              alt=""
              decoding="async"
              fetchpriority="high"
            />
          </picture>
        </div>
        <div
          class="contact-page__fit-content contact-page__fit-content--pending"
          aria-busy="true"
        >
          <div class="contact-page__inset-rect contact-page__inset-rect--intro">
            <p class="contact-page__intro contact-page__intro--lead">
              Glad you made it this far
            </p>
            <p class="contact-page__intro contact-page__intro--deck">
              If we think alike, there’s probably something worth building
              together.{' '}
              <span class="contact-page__intro-reach">Reach out.</span>
            </p>
          </div>
          <div class="contact-page__inset-rect contact-page__inset-rect--links">
            <nav class="contact-page__links" aria-label="Contact and profiles">
              <a href="/contact/form" class="contact-extra-link">
                <img
                  class="contact-extra-link__icon contact-extra-link__icon--bubble"
                  src="/assets/pages/contact/bubble.png"
                  alt=""
                  loading="eager"
                  decoding="async"
                />
                <span class="contact-extra-link__text">Direct contact</span>
              </a>
              <a
                class="contact-extra-link"
                href="https://github.com/havlinj"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  class="contact-extra-link__icon"
                  src="/assets/pages/contact/github.svg"
                  alt=""
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
                />
                <span class="contact-extra-link__text">GitHub</span>
              </a>
              <a
                class="contact-extra-link"
                href="https://www.linkedin.com/in/jan-havlin"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  class="contact-extra-link__icon"
                  src="/assets/pages/contact/InBug-Black.png"
                  alt=""
                  width="24"
                  height="24"
                  loading="eager"
                  decoding="async"
                />
                <span class="contact-extra-link__text">LinkedIn</span>
              </a>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </article>

  <noscript>
    <style>
      .contact-page
        .contact-page__fit-content.contact-page__fit-content--pending {
        opacity: 1 !important;
        pointer-events: auto !important;
      }
    </style>
  </noscript>

  <script>
    import '../scripts/contact-layout-fit.ts';
  </script>
</Layout>
