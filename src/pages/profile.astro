---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const page = await getEntry('pages', 'profile');
if (!page) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}
const { Content } = await render(page);
---

<Layout title={page.data.title} activeSection="profile" profileStylesLast>
  <article class="has-buttons-panel">
    <h1 class="page-title">{page.data.title}</h1>
    <Content />
  </article>
  <script>
    import '../scripts/profile-tile-type-fit.ts';
  </script>
</Layout>
