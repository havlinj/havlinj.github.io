---
import Layout from '../layouts/Layout.astro';
import '../styles/home.css';
---

<Layout title="Jan Havlín">
  <Fragment slot="head">
    <link rel="preload" href="/assets/hero/hero-bg.jpg" as="image" />
  </Fragment>
  <header class="hero-header">
    <div class="hero-header__inner">
      <a href="/profile" class="site-header__item site-nav__link">Profile</a>
      <a href="/writing" class="site-header__item site-nav__link">Writing</a>
      <a href="/contact" class="site-header__item site-nav__link">Contact</a>
    </div>
  </header>
  <h1>Hi there</h1>
  <section class="hero">
    <div class="hero-top-edge" aria-hidden="true"></div>
    <div class="hero-bg" aria-hidden="true">
      <img
        src="/assets/hero/hero-bg.jpg"
        alt=""
        class="hero-bg__image"
        fetchpriority="high"
        decoding="async"
      />
    </div>

    <div class="hero-content">
      <div class="hero-grid">
        <div class="hero-name-box">
          <h1 class="hero-name" data-fit-text>Jan Havlín</h1>
        </div>
        <div class="hero-role">
          <span>BACKEND ARCHITECTURE</span>
          <span>& SYSTEMS</span>
        </div>
      </div>
      <p class="tagline">
        <span class="tagline__glow-wrap" aria-hidden="true">
          <span class="tagline__glow">Building reliable,<br>fast and high-impact<br>software<br></span>
          <span class="tagline__glow tagline__glow--last">from the ground up</span>
        </span>
        <span class="tagline__text">Building reliable,<br>fast and high-impact<br>software<br>from the ground up</span>
      </p>
    </div>
  </section>
  <script is:inline>
    (function () {
      'use strict';

      function showHeroWhenBgReady() {
        const hero = document.querySelector('.hero');
        const img = hero?.querySelector('.hero-bg__image');
        if (!hero || !img) return;
        if (img.complete) hero.classList.add('is-loaded');
        else img.addEventListener('load', () => hero.classList.add('is-loaded'));
      }
      showHeroWhenBgReady();

      function fitTextToContainer(textEl, options = {}) {
        const container = textEl.parentElement;
        if (!container) return;

        const minFont = options.minFont ?? 16;
        const maxFont = options.maxFont ?? 220;
        const precision = options.precision ?? 0.25;
        let low = minFont;
        let high = maxFont;
        let best = minFont;

        textEl.style.fontSize = minFont + 'px';
        while (high - low > precision) {
          const mid = (low + high) / 2;
          textEl.style.fontSize = mid + 'px';
          if (textEl.scrollWidth <= container.clientWidth) {
            best = mid;
            low = mid;
          } else {
            high = mid;
          }
        }
        textEl.style.fontSize = best + 'px';
      }

      function fitAllHeroNames() {
        document.querySelectorAll('[data-fit-text]').forEach((el) => {
          fitTextToContainer(el, { minFont: 16, maxFont: 220, precision: 0.1 });
        });
      }

      function fitHeroRoles() {
        const heroNameEl = document.querySelector('.hero-name');
        if (!heroNameEl) return;

        const heroNameSize =
          parseFloat(getComputedStyle(heroNameEl).fontSize) || 0;

        document.querySelectorAll('.hero-role').forEach((roleEl) => {
          const spans = Array.from(roleEl.querySelectorAll('span'));
          if (spans.length === 0) return;

          const minFont = 10;
          const precision = 0.1;
          const highCap = heroNameSize || 120;
          let low = minFont;
          let high = highCap;
          let bestWidth = minFont;

          spans.forEach((s) => (s.style.fontSize = minFont + 'px'));
          while (high - low > precision) {
            const mid = (low + high) / 2;
            spans.forEach((s) => (s.style.fontSize = mid + 'px'));
            const fits = spans.every(
              (s) => s.scrollWidth <= roleEl.clientWidth
            );
            if (fits) {
              bestWidth = mid;
              low = mid;
            } else {
              high = mid;
            }
          }

          const ratioLimitMax = 0.4;
          const ratioLimitMin = 0.3;
          let roleFont = bestWidth;
          if (heroNameSize) {
            roleFont = Math.min(roleFont, heroNameSize * ratioLimitMax);
            roleFont = Math.max(roleFont, heroNameSize * ratioLimitMin);
          }
          spans.forEach((s) => (s.style.fontSize = roleFont + 'px'));
        });
      }

      let scheduledFit = false;
      function scheduleHeroFit() {
        if (scheduledFit) return;
        scheduledFit = true;
        requestAnimationFrame(() => {
          scheduledFit = false;
          fitAllHeroNames();
          fitHeroRoles();
        });
      }

      function initHeroParallax() {
        const hero = document.querySelector('.hero');
        const img = hero?.querySelector('.hero-bg__image');
        if (!hero || !img) return;

        const maxTranslate = 24;
        function updateParallax() {
          const rect = hero.getBoundingClientRect();
          const vh = window.innerHeight || document.documentElement.clientHeight;
          if (vh === 0) return;

          const rawProgress = 1 - rect.top / vh;
          const clamped = Math.min(1, Math.max(0, rawProgress));
          const scrollOffset = (clamped - 0.5) * 2 * maxTranslate;
          const vw = window.innerWidth || document.documentElement.clientWidth;
          const horizontalOffset = (vw / 1200 - 1) * 18;

          img.style.transform =
            `translate3d(${horizontalOffset}px, ${scrollOffset}px, 0) scale(1.06)`;
        }

        updateParallax();
        window.addEventListener('scroll', updateParallax, { passive: true });
        window.addEventListener('resize', updateParallax);
      }

      const resizeObserver = new ResizeObserver(scheduleHeroFit);

      function onLoad() {
        fitAllHeroNames();
        fitHeroRoles();
        initHeroParallax();
        document
          .querySelectorAll('.hero-name-box, .hero-role')
          .forEach((el) => resizeObserver.observe(el));
      }

      window.addEventListener('load', onLoad);
      window.addEventListener('resize', scheduleHeroFit);

      document.fonts?.ready?.then(() => {
        fitAllHeroNames();
        fitHeroRoles();
      });
    })();
  </script>
</Layout>
