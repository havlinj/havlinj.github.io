---
import Layout from '../layouts/Layout.astro';
import '../styles/home.css';
---

<Layout title="Jan Havlín">
  <header class="hero-header">
    <div class="hero-header__inner">
      <a href="/profile" class="site-header__item site-nav__link">Profile</a>
      <a href="/writing" class="site-header__item site-nav__link">Writing</a>
      <a href="/contact" class="site-header__item site-nav__link">Contact</a>
    </div>
  </header>
  <h1>Hello</h1>
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <img
        src="/assets/hero/hero-bg.jpg"
        alt=""
        class="hero-bg__image"
        loading="lazy"
      />
    </div>

    <div class="hero-content">
      <div class="hero-grid">
        <div class="hero-name-box">
          <h1 class="hero-name" data-fit-text>Jan Havlín</h1>
        </div>
        <div class="hero-role">
          <div class="hero-role-line">
            <span>BACKEND ARCHITECTURE</span>
          </div>
          <div class="hero-role-line">
            <span>& SYSTEMS</span>
          </div>
        </div>
      </div>
      <p class="tagline">
        Building reliable, fast and high-impact software from the ground up
      </p>
    </div>
  </section>
  <script is:inline>
    (function () {
      function fitTextToContainer(textEl, options = {}) {
        const container = textEl.parentElement;
        if (!container) return;

        const minFont = options.minFont ?? 16;
        const maxFont = options.maxFont ?? 220;
        const precision = options.precision ?? 0.25;

        let low = minFont;
        let high = maxFont;
        let best = minFont;

        textEl.style.fontSize = minFont + 'px';

        while (high - low > precision) {
          const mid = (low + high) / 2;
          textEl.style.fontSize = mid + 'px';

          if (textEl.scrollWidth <= container.clientWidth) {
            best = mid;
            low = mid;
          } else {
            high = mid;
          }
        }

        textEl.style.fontSize = best + 'px';
      }

      function fitAllHeroNames() {
        document.querySelectorAll('[data-fit-text]').forEach((el) => {
          fitTextToContainer(el, {
            minFont: 16,
            maxFont: 220,
            precision: 0.1,
          });
        });
      }

      function fitHeroRoles() {
        const heroNameEl = document.querySelector('.hero-name');
        const heroNameBox = document.querySelector('.hero-name-box');
        if (!heroNameEl || !heroNameBox) return;

        const heroNameStyle = window.getComputedStyle(heroNameEl);
        const heroNameSize =
          parseFloat(heroNameStyle.fontSize || '0') || 0; // H (font-size jména)
        const heroHeight = heroNameBox.getBoundingClientRect().height; // skutečná výška pásma vlevo

        if (!heroNameSize || !heroHeight) return;

        document.querySelectorAll('.hero-role').forEach((roleEl) => {
          const spans = Array.from(roleEl.querySelectorAll('span'));
          if (spans.length === 0) return;

          const container = roleEl;
          const minFont = 10;
          const precision = 0.1;

          // 1) šířkové omezení: binární hledání maximální velikosti, která se vejde do šířky
          let low = minFont;
          let high = heroNameSize; // role nikdy nebude větší než jméno
          let bestWidth = minFont;

          spans.forEach((s) => {
            s.style.fontSize = minFont + 'px';
          });

          while (high - low > precision) {
            const mid = (low + high) / 2;
            spans.forEach((s) => {
              s.style.fontSize = mid + 'px';
            });

            const fits = spans.every(
              (s) => s.scrollWidth <= container.clientWidth,
            );

            if (fits) {
              bestWidth = mid;
              low = mid;
            } else {
              high = mid;
            }
          }

          // 2) vertikální omezení: najdi role-size a mezeru tak, aby se 2 řádky + mezera vešly do heroHeight
          const ratioLimit = 0.25; // role-font <= 25 % fontu jména
          const maxRoleByRatio = heroNameSize * ratioLimit;
          const maxRoleCandidate = Math.min(bestWidth, maxRoleByRatio);
          const gapFactor = 0.6; // gap = 0.6 * role-font

          if (maxRoleCandidate <= minFont) {
            // fallback – použij šířkový výsledek bez speciálního vertikálního ladění
            spans.forEach((s, idx) => {
              s.style.fontSize = bestWidth + 'px';
              s.style.marginBottom = idx === 0 && spans.length > 1
                ? bestWidth * gapFactor + 'px'
                : '0px';
            });
            return;
          }

          let vLow = minFont;
          let vHigh = maxRoleCandidate;
          let bestVertical = vLow;

          function totalHeightForFont(sizePx) {
            let total = 0;
            spans.forEach((s, idx) => {
              s.style.fontSize = sizePx + 'px';
              s.style.marginBottom = '0px';
              const rect = s.getBoundingClientRect();
              total += rect.height;
              if (idx === 0 && spans.length > 1) {
                total += sizePx * gapFactor;
              }
            });
            return total;
          }

          while (vHigh - vLow > precision) {
            const mid = (vLow + vHigh) / 2;
            const total = totalHeightForFont(mid);

            if (total <= heroHeight) {
              bestVertical = mid;
              vLow = mid;
            } else {
              vHigh = mid;
            }
          }

          const finalSize = bestVertical;
          const gapPx = finalSize * gapFactor;

          // 3) aplikuj finální velikost a mezeru
          spans.forEach((s, idx) => {
            s.style.fontSize = finalSize + 'px';
            if (idx === 0 && spans.length > 1) {
              s.style.marginBottom = gapPx + 'px';
            } else {
              s.style.marginBottom = '0px';
            }
          });
        });
      }

      let scheduledFit = false;
      function scheduleHeroFit() {
        if (scheduledFit) return;
        scheduledFit = true;
        window.requestAnimationFrame(() => {
          scheduledFit = false;
          fitAllHeroNames();
          fitHeroRoles();
        });
      }

      function initHeroParallax() {
        const hero = document.querySelector('.hero');
        if (!hero) return;

        const img = hero.querySelector('.hero-bg__image');
        if (!img) return;

        const maxTranslate = 24; // px

        function updateParallax() {
          const rect = hero.getBoundingClientRect();
          const viewportHeight =
            window.innerHeight || document.documentElement.clientHeight;

          if (viewportHeight === 0) return;

          const rawProgress = 1 - rect.top / viewportHeight;
          const clamped = Math.min(1, Math.max(0, rawProgress));
          const scrollOffset = (clamped - 0.5) * 2 * maxTranslate;

          const viewportWidth =
            window.innerWidth || document.documentElement.clientWidth;
          const widthFactor = viewportWidth / 1200;
          const horizontalOffset = (widthFactor - 1) * 18;

          img.style.transform = `translate3d(${horizontalOffset}px, ${scrollOffset}px, 0) scale(1.06)`;
        }

        updateParallax();

        window.addEventListener('scroll', updateParallax, { passive: true });
        window.addEventListener('resize', updateParallax);
      }

      const resizeObserver = new ResizeObserver(() => {
        scheduleHeroFit();
      });

      window.addEventListener('load', () => {
        fitAllHeroNames();
        fitHeroRoles();
        initHeroParallax();

        document.querySelectorAll('.hero-name-box').forEach((box) => {
          resizeObserver.observe(box);
        });

        document.querySelectorAll('.hero-role').forEach((box) => {
          resizeObserver.observe(box);
        });
      });

      window.addEventListener('resize', () => {
        scheduleHeroFit();
      });

      window.addEventListener('scroll', () => {
        scheduleHeroFit();
      });

      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(() => {
          fitAllHeroNames();
          fitHeroRoles();
        });
      }
    })();
  </script>
</Layout>
