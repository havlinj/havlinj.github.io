---
import Layout from '../layouts/Layout.astro';
import '../styles/hero.css';

const heroBgStem =
  '/assets/hero/altumcode-oZ61KFUQsus-unsplash_dichrom';
const heroBgResponsive = {
  w720: { href: `${heroBgStem}_720.png`, w: 1620 },
  w1080: { href: `${heroBgStem}_1080.png`, w: 2160 },
  w1440: { href: `${heroBgStem}_1440.png`, w: 2736 },
  w1920: { href: `${heroBgStem}_1920.png`, w: 3360 },
  w2400: { href: `${heroBgStem}_2400.png`, w: 3840 },
} as const;
---

<Layout title="Jan Havlín">
  <Fragment slot="head">
    <link
      rel="preload"
      href={heroBgResponsive.w1440.href}
      as="image"
    />
  </Fragment>
  <nav class="hero-header" aria-label="Main navigation">
    <div class="hero-header__inner">
      <a href="/profile" class="site-header__item site-nav__link">Profile</a>
      <a href="/writing" class="site-header__item site-nav__link">Writing</a>
      <a href="/contact" class="site-header__item site-nav__link">Contact</a>
    </div>
  </nav>
  <!-- Spacing below "Hi there": must match `h1 + .hero-wrap` in hero.css (1.1rem).
       With `.hero-top-edge` (0.25rem) the perceived gap to visible photo ≈ 1.35rem. -->
  <h1
    class="page-title"
    style="--page-title-margin-bottom: 1.1rem; --hero-title-gap: 1.1rem"
  >
    Hi there
  </h1>
  <div class="hero-wrap">
    <section class="hero">
      <div class="hero-top-edge" aria-hidden="true"></div>
      <figure class="hero-figure">
        <div class="hero-bg" aria-hidden="true">
          <picture>
            <source
              media="(max-width: 767px)"
              srcset={`${heroBgResponsive.w720.href} ${heroBgResponsive.w720.w}w, ${heroBgResponsive.w1080.href} ${heroBgResponsive.w1080.w}w`}
              sizes="100vw"
            />
            <img
              src={heroBgResponsive.w1440.href}
              srcset={`${heroBgResponsive.w1080.href} ${heroBgResponsive.w1080.w}w, ${heroBgResponsive.w1440.href} ${heroBgResponsive.w1440.w}w, ${heroBgResponsive.w1920.href} ${heroBgResponsive.w1920.w}w, ${heroBgResponsive.w2400.href} ${heroBgResponsive.w2400.w}w`}
              sizes="100vw"
              width="2736"
              height="3420"
              alt="Hero background"
              class="hero-bg__image"
              fetchpriority="high"
              decoding="async"
            />
          </picture>
        </div>
      </figure>

      <div class="hero-content">
        <div class="hero-grid">
          <div class="hero-name-box">
            <h1 class="hero-name" data-fit-text>Jan Havlín</h1>
          </div>
          <div class="hero-role">
            <span>BACKEND ARCHITECTURE</span>
            <span>& SYSTEMS</span>
          </div>
        </div>
        <p class="tagline">
          <span class="tagline__text"
            >Building reliable,<br />fast and high-impact<br />software<br
            />from the ground up</span
          >
        </p>
      </div>
    </section>
  </div>
  <script is:inline>
    (function () {
      'use strict';

      const SEL = {
        hero: '.hero',
        heroBgImage: '.hero-bg__image',
      };

      function revealHeroWhenImageReady() {
        const hero = document.querySelector(SEL.hero);
        const heroImg = document.querySelector(SEL.heroBgImage);
        if (!(hero instanceof HTMLElement)) return;
        if (!(heroImg instanceof HTMLImageElement)) {
          hero.classList.add('hero--ready');
          return;
        }

        const reveal = () => hero.classList.add('hero--ready');
        if (heroImg.complete && heroImg.naturalWidth > 0) {
          reveal();
          return;
        }
        heroImg.addEventListener('load', reveal, { once: true });
        heroImg.addEventListener('error', reveal, { once: true });
      }

      function onLoad() {
        revealHeroWhenImageReady();
      }

      window.addEventListener('load', onLoad);
    })();
  </script>
</Layout>
