<form id="contact-form" class="contact-form" novalidate autocomplete="off">
  <label>
    Name
    <input
      type="text"
      name="name"
      maxlength="100"
      required
      autocomplete="name"
    />
  </label>

  <label>
    Email
    <input type="email" name="email" required autocomplete="email" />
  </label>

  <label>
    Message
    <textarea
      name="message"
      minlength="10"
      maxlength="5000"
      required
      autocomplete="off"></textarea>
  </label>

  <div class="hidden" aria-hidden="true">
    <label>
      Company
      <input
        type="text"
        name="company"
        tabindex="-1"
        autocomplete="off"
        inputmode="none"
      />
    </label>
  </div>

  <div class="cf-turnstile" data-sitekey="0x4AAAAAACpJlpuMEv-nLyuB"></div>

  <div class="contact-form__actions">
    <button type="submit">Send</button>
    <p id="status" class="contact-status" role="status" aria-live="polite"></p>
  </div>
</form>

<script is:inline>
  (() => {
    const SELECTORS = {
      form: '#contact-form',
      status: '#status',
      submitButton: 'button[type="submit"]',
    };
    const FIELD_NAMES = ['name', 'email', 'message', 'company'];

    const form = document.querySelector(SELECTORS.form);
    const status = document.querySelector(SELECTORS.status);

    if (!form || !status) return;

    const sendButton = form.querySelector(SELECTORS.submitButton);

    function replaceContactFieldsWithFreshElements() {
      for (const fieldName of FIELD_NAMES) {
        const oldEl = form.querySelector('[name="' + fieldName + '"]');
        if (!oldEl) continue;
        const tag = oldEl.tagName.toLowerCase();
        if (tag !== 'input' && tag !== 'textarea') continue;
        const fresh = document.createElement(tag);
        for (let i = 0; i < oldEl.attributes.length; i++) {
          const a = oldEl.attributes[i];
          fresh.setAttribute(a.name, a.value);
        }
        oldEl.replaceWith(fresh);
      }
    }

    let isSubmitting = false;
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSubmitting) return;
      isSubmitting = true;
      if (sendButton) sendButton.disabled = true;

      status.textContent = 'Sending...';

      const formData = new FormData(form);

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.ok) {
          status.textContent = 'Thanks! Your message has been sent.';
          if (window.turnstile) {
            window.turnstile.reset();
          }
          form.reset();
          replaceContactFieldsWithFreshElements();
        } else {
          status.textContent = data.error || 'Something went wrong.';

          if (window.turnstile && data.resetTurnstile) {
            window.turnstile.reset();
          }
        }
      } catch {
        status.textContent = 'Network error. Please try again.';

        if (window.turnstile) {
          window.turnstile.reset();
        }
      } finally {
        isSubmitting = false;
        if (sendButton) sendButton.disabled = false;
      }
    });
  })();
</script>
