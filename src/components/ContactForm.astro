<form id="contact-form" class="contact-form" novalidate autocomplete="off">
  <label>
    Name
    <input
      type="text"
      name="name"
      maxlength="100"
      required
      autocomplete="name"
    />
  </label>

  <label>
    Email
    <input type="email" name="email" required autocomplete="email" />
  </label>

  <label>
    Message
    <textarea
      name="message"
      minlength="10"
      maxlength="5000"
      required
      autocomplete="off"></textarea>
  </label>

  <div class="hidden" aria-hidden="true">
    <label>
      Company
      <input
        type="text"
        name="company"
        tabindex="-1"
        autocomplete="off"
        inputmode="none"
      />
    </label>
  </div>

  <div class="cf-turnstile" data-sitekey="0x4AAAAAACpJlpuMEv-nLyuB"></div>

  <div class="contact-form__actions">
    <button type="submit">Send</button>
    <p id="status" class="contact-status" role="status" aria-live="polite"></p>
  </div>
</form>

<script>
  import { setupContactForm } from '../scripts/contact-form';
  setupContactForm();
</script>
