---
import AnimatedArrow from './AnimatedArrow.astro';
---

<section class="why-wrapper">
  <div class="why-box">
    <div class="why-end-cover" aria-hidden="true"></div>
    <div class="why-start-cover" aria-hidden="true"></div>
    <div class="why-scroll-cta" aria-hidden="true">
      <AnimatedArrow
        direction="down"
        sizeScale={1.5}
        sizeMode="responsive"
        color="#e0f7fa"
        duration={2}
        opacity={0.35}
        grainOpacity={0.28}
        grainSize={220}
      />
    </div>
    <div class="why-scroll">
      <div class="why-content why-content--pending-layout">
        <div class="why-spacer why-spacer--top" aria-hidden="true"></div>

        <div class="why-gif-holder" aria-hidden="true">
          <div class="why-gif-frame">
            <!-- Placeholder GIF URL (replace later with your real asset). -->
            <img
              class="why-gif"
              src="/assets/pages/profile/why/nicola_narracci_14570518_1920_1080_30fps_pexels_dichrom.gif"
              alt=""
              loading="eager"
              decoding="async"
            />
          </div>
        </div>

        <div class="why-block why-block--intro">
          <p class="why-lead">I'm a software engineer.</p>

          <p class="why-p--wide">
            Platforms like LinkedIn or GitHub are useful —<br />
            but they say little about how someone actually thinks.
          </p>

          <p class="why-anchor">
            This site is an attempt to make that visible.
          </p>
        </div>

        <div class="why-block why-block--body">
          <p>
            I believe judgment and perspective matter<br />
            as much as technical skill.<br />
            Writing is how I explore and articulate both.
          </p>

          <p>
            I'm ambitious and drawn to<br />
            building things that matter.
          </p>

          <p>
            Doing it well requires more than code —<br />
            it requires the right mindset.
          </p>
        </div>

        <div class="why-block why-block--close">
          <p>
            There are no project showcases here.<br />
            Only thoughts and reflections — in Writing.
          </p>

          <p class="why-close">
            If this resonates,<br />
            you probably already know why you're here.
          </p>
        </div>

        <div class="why-spacer why-spacer--bottom" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const scrollEl = document.querySelector('.why-page .why-scroll');
    if (!scrollEl) return;
    const boxEl = scrollEl.closest('.why-box');
    if (!boxEl) return;
    const ctaEl = boxEl.querySelector('.why-scroll-cta');
    const contentEl = scrollEl.querySelector('.why-content');
    if (!contentEl) return;
    const topSpacer = scrollEl.querySelector('.why-spacer--top');
    const bottomSpacer = scrollEl.querySelector('.why-spacer--bottom');
    if (!topSpacer || !bottomSpacer) return;

    const lines = Array.from(scrollEl.querySelectorAll('p'));
    if (lines.length === 0) return;

    const gifEl = scrollEl.querySelector('.why-gif-holder');

    const clamp = (v, min, max) => Math.min(max, Math.max(min, v));
    const smoothstep = (x) => x * x * (3 - 2 * x);

    let rafId = 0;
    const schedule = () => {
      if (rafId) return;
      rafId = requestAnimationFrame(update);
    };

    function update() {
      rafId = 0;
      const maxScroll = Math.max(
        0,
        scrollEl.scrollHeight - scrollEl.clientHeight,
      );
      const boxRect = scrollEl.getBoundingClientRect();
      const half = boxRect.height / 2;
      const center = boxRect.top + half;
      const firstLine = lines[0];
      const firstRect = firstLine.getBoundingClientRect();
      const firstHeight = firstRect.height || 0;
      const gifHeight = gifEl ? gifEl.getBoundingClientRect().height || 0 : 0;
      const scrollStyle = window.getComputedStyle(scrollEl);
      const padTop = Number.parseFloat(scrollStyle.paddingTop) || 0;
      const padBottom = Number.parseFloat(scrollStyle.paddingBottom) || 0;

      // Early-phase bottom cover: briefly hide the initial partial line at the
      // very bottom and dissolve it quickly as the reader starts scrolling.
      const startBandPx = Math.max(85, scrollEl.clientHeight * 0.26);
      const startProgress = clamp(scrollEl.scrollTop / startBandPx, 0, 1);
      const startOpacity = 1 - smoothstep(startProgress);
      boxEl.style.setProperty(
        '--why-start-cover-opacity',
        startOpacity.toFixed(3),
      );

      // Scroll hint: hide quickly once the reader starts scrolling.
      const ctaFadePx = 56;
      const ctaProgress = clamp(scrollEl.scrollTop / ctaFadePx, 0, 1);
      const ctaO = 1 - smoothstep(ctaProgress);
      boxEl.style.setProperty('--why-cta-opacity', ctaO.toFixed(3));
      if (ctaEl) {
        ctaEl.style.visibility = ctaO < 0.002 ? 'hidden' : 'visible';
      }

      // Near the very end, we fade in a top cover to hide earlier text that
      // would otherwise linger while we keep the last lines stable.
      const coverBandPx = Math.max(70, scrollEl.clientHeight * 0.22);
      const coverProgress = maxScroll
        ? clamp(
            (scrollEl.scrollTop - (maxScroll - coverBandPx)) / coverBandPx,
            0,
            1,
          )
        : 0;
      boxEl.style.setProperty(
        '--why-end-cover-opacity',
        smoothstep(coverProgress).toFixed(3),
      );

      /*
       * Opening: first two <p> only (lead + LinkedIn block ≈ three typographic lines).
       * introBlend also drives --why-top-edge-opacity so .why-box::before does not sit
       * semi-transparent over type at scrollTop 0 (that read as “dimmed” text).
       */
      const introLineCount = 2;
      const introRampPx = Math.max(100, scrollEl.clientHeight * 0.22);
      const introBlend = smoothstep(
        clamp(scrollEl.scrollTop / introRampPx, 0, 1),
      );
      boxEl.style.setProperty(
        '--why-top-edge-opacity',
        introBlend.toFixed(3),
      );

      // Place the first line so its TOP edge sits on the box center line.
      // This keeps the lead text visually centered even when a GIF sits above it.
      // We then apply a small additional downward bias to match the desired composition.
      const leadDownPx = firstHeight * 0.18;
      const topSpacerPx = Math.max(0, half - padTop - gifHeight + leadDownPx);
      // Allow a bit more room near the end so the last line doesn't get
      // "stuck" too early. This is a bottom-only tweak, so earlier phases
      // (including the start) remain stable.
      const endScrollExtraPx = half * 0.32;
      const bottomSpacerPx = Math.max(
        0,
        half - padBottom - gifHeight + endScrollExtraPx,
      );
      topSpacer.style.height = `${topSpacerPx.toFixed(2)}px`;
      bottomSpacer.style.height = `${bottomSpacerPx.toFixed(2)}px`;

      // Wider transition zone to avoid abrupt threshold jumps.
      const centerBand = 0.4;
      const transitionBand = 0.45;

      lines.forEach((line, lineIndex) => {
        const r = line.getBoundingClientRect();
        const mid = (r.top + r.bottom) / 2;
        const normalized = Math.abs(mid - center) / half; // 0..1

        const edgeProgress = clamp(
          (normalized - centerBand) / transitionBand,
          0,
          1,
        );
        const eased = smoothstep(edgeProgress);
        const gate = lineIndex < introLineCount ? introBlend : 1;
        const blendedEased = eased * gate;

        const isLead = line.classList.contains('why-lead');
        // Lead line scales/insets less aggressively so its typographic emphasis remains visible.
        const scaleDrop = isLead ? 0.3 : 0.5;
        const maxInset = isLead ? 2.4 : 4;
        const scale = 1 - scaleDrop * blendedEased;
        const inset = maxInset * blendedEased;

        line.style.setProperty('--why-line-scale', scale.toFixed(3));
        line.style.setProperty('--why-line-inset', `${inset.toFixed(3)}rem`);
      });

      // Drive the GIF with the same center-based geometry as the text lines.
      // We fade it out as it moves away from the box center, while also applying
      // the same scale + inset feel as the paragraphs.
      if (gifEl) {
        const r = gifEl.getBoundingClientRect();
        const mid = (r.top + r.bottom) / 2;
        const normalized = Math.abs(mid - center) / half; // 0..1

        const edgeProgress = clamp(
          (normalized - centerBand) / transitionBand,
          0,
          1,
        );
        const eased = smoothstep(edgeProgress);
        const gifEased = eased * introBlend;

        // Visually lift the GIF higher than the lead line
        // without affecting the lead line centering math.
        const liftPx = firstHeight * 0.75;
        gifEl.style.setProperty('--why-gif-y', `${(-liftPx).toFixed(2)}px`);

        const scaleDrop = 0.35;
        const maxInset = 3.2;
        const scale = 1 - scaleDrop * gifEased;
        const inset = maxInset * gifEased;

        gifEl.style.setProperty('--why-line-scale', scale.toFixed(3));
        gifEl.style.setProperty('--why-line-inset', `${inset.toFixed(3)}rem`);

        const opacityDrop = 0.75;
        const opacity = clamp(1 - opacityDrop * gifEased, 0, 1);
        gifEl.style.setProperty('--why-gif-opacity', opacity.toFixed(3));
      }
    }

    function afterTwoFrames(fn) {
      requestAnimationFrame(() => requestAnimationFrame(fn));
    }

    function revealAfterStableLayout() {
      // Run two passes so spacer math settles after style/layout changes.
      update();
      update();
      contentEl.classList.remove('why-content--pending-layout');
      contentEl.classList.add('why-content--ready');
    }

    function init() {
      // Wait for font metrics to settle to avoid first-paint jump.
      const fontsReady = document.fonts?.ready ?? Promise.resolve();
      fontsReady.finally(() => afterTwoFrames(revealAfterStableLayout));
    }

    scrollEl.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', schedule);
    init();
  })();
</script>
