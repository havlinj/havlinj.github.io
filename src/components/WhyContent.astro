---
import AnimatedArrow from './AnimatedArrow.astro';
import {
  WHY_CTA_ARROW_FLOOR_OPACITY,
  WHY_CTA_ARROW_PEAK_OPACITY,
  WHY_CTA_BOX_WIDTH_FRAC,
  WHY_GIF_BASE_OPACITY,
  WHY_GIF_TOP_INSET,
  WHY_SCROLL_CTA_CONTAINER_CQW,
} from '../constants/why-layout';
import '../styles/why.css';
---

<section
  class="why-wrapper"
  style={{
    '--why-gif-top-inset': WHY_GIF_TOP_INSET,
    '--why-gif-base-opacity': String(WHY_GIF_BASE_OPACITY),
  }}
>
  <div
    class="why-box"
    style={{
      '--why-cta-horizontal': `${WHY_CTA_BOX_WIDTH_FRAC * 100}%`,
    }}
  >
    <div class="why-end-cover" aria-hidden="true"></div>
    <div class="why-cta-veil" aria-hidden="true"></div>
    <div class="why-scroll-cta" aria-hidden="true">
      <AnimatedArrow
        variant="solid-blink"
        direction="down"
        sizeMode="container"
        containerCqw={WHY_SCROLL_CTA_CONTAINER_CQW}
        color="var(--color-page-bg)"
        duration={2}
        solidBlinkPeakOpacity={WHY_CTA_ARROW_PEAK_OPACITY}
        solidBlinkFloorOpacity={WHY_CTA_ARROW_FLOOR_OPACITY}
      />
    </div>
    <div class="why-scroll">
      <span class="why-fit-probe" aria-hidden="true"></span>
      <div class="why-content why-content--pending-layout">
        <div class="why-spacer why-spacer--top" aria-hidden="true"></div>

        <div class="why-clip-holder" aria-hidden="true">
          <div class="why-clip-frame">
            <video
              class="why-clip"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-hidden="true"
            >
              <source
                src="/assets/pages/profile/why/nicola_narraci_15717076_1280_720_30fps_pexels_reverse_loop_dichrom.mp4"
                type="video/mp4"
              />
            </video>
          </div>
        </div>

        <div class="why-block why-block--intro">
          <p class="why-lead">I'm a software engineer.</p>

          <p class="why-p--wide">
            Platforms like <em>LinkedIn</em> or <em>GitHub</em> are useful&nbsp;—<br
            />
            but they say little about how someone actually thinks.
          </p>

          <p class="why-anchor">
            This site is an attempt to make that visible.
          </p>
        </div>

        <div class="why-block why-block--body">
          <p>
            I believe judgment and perspective matter<br />
            as much as technical skill.<br />
            Writing is how I explore and articulate both.
          </p>

          <p>
            I'm ambitious and drawn to<br />
            building things that have meaning and impact.
          </p>

          <p>
            Doing it well requires more than code —<br />
            it requires the right mindset.
          </p>
        </div>

        <div class="why-block why-block--close">
          <p>
            There are no project showcases here.<br />
            Only thoughts and reflections — in Writing.
          </p>

          <p class="why-close">
            If this resonates,<br />
            you probably already know why you're here.
          </p>
        </div>

        <div class="why-spacer why-spacer--bottom" aria-hidden="true"></div>
      </div>
      <div class="why-start-cover" aria-hidden="true"></div>
    </div>
    <div class="why-intro-top-band" aria-hidden="true"></div>
    <!-- Fixed to .why-box bottom — not inside .why-scroll (would scroll with content). -->
    <div class="why-box-step2-veil" aria-hidden="true"></div>
    <div class="why-box-bottom-veil" aria-hidden="true"></div>
    <div class="why-box-step3-veil" aria-hidden="true"></div>
  </div>
</section>

<script>
  import '../scripts/why-box-scroll.ts';
</script>
