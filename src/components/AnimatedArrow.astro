---
import '../styles/animated-arrow.css';
/**
 * Segmented chevron; the root `<span>` is not faded so #111 panels behind the arrow (e.g. /why)
 * don’t wash out.
 *
 * Sizing: `fixed` — `size` px; `responsive` — clamp(rem+vw) capped by `size` (scales faster than layout at zoom).
 * `container` — `width: N cqw` on a `container-type: size` ancestor (arrow tracks that box; tame page zoom).
 */
// eslint-disable-next-line no-unused-vars, @typescript-eslint/no-unused-vars -- Astro `Props` → `Astro.props`
interface Props {
  size?: number;
  sizeMode?: 'fixed' | 'responsive' | 'container';
  /** With `sizeMode="container"`: width as % of named container width (`cqw`). Ancestor needs `container-type: size`. */
  containerCqw?: number;
  /** Multiplies `size` and responsive rem/vw terms (default 1). */
  sizeScale?: number;
  /** Responsive only: max arrow width in px after the rem/vw clamp (outer cap, not the clamp’s own `size` ceiling). */
  responsiveClampMaxPx?: number;
  /** Responsive only: `min(clamp(...), N vmin)` (viewport-based). */
  responsiveMaxVmin?: number;
  /** Responsive only: `min(clamp(...), N cqmin)`; ancestor must set `container-type: size` (e.g. .why-box). */
  responsiveMaxCqmin?: number;
  /** Responsive only: `min(clamp(...), N cqw)` — cap as % of container width (good when zoom shrinks the box). */
  responsiveMaxCqw?: number;
  color?: string;
  duration?: number;
  class?: string;
  direction?: 'up' | 'down';
  opacity?: number;
  /** Optional image URL mapped as texture inside arrow segments. */
  textureUrl?: string;
  /** Optional CSS filter controls for texture image. */
  textureBrightness?: number;
  textureContrast?: number;
  /** Optional texture zoom (>1 = zoom in, <1 = zoom out). */
  textureZoom?: number;
}

const VIEWBOX_W = 220;
const VIEWBOX_H = 170;

const RESPONSIVE_WIDTH = {
  minRem: 2.55,
  baseRem: 2.15,
  vw: 1.05,
  /** Lower clamp vs `size`: min(rem floor, size * this). */
  minSizeFactor: 0.72,
} as const;

/** Default `sizeScale`; override per `<AnimatedArrow sizeScale={…} />`. */
const DEFAULT_SIZE_SCALE = 1;

const props = Astro.props;

const sizePx = (() => {
  const n = Number(props.size);
  return Number.isFinite(n) && n > 0 ? n : 120;
})();

const sizeScale = (() => {
  const raw = Number(props.sizeScale ?? DEFAULT_SIZE_SCALE);
  if (!Number.isFinite(raw) || raw <= 0) return DEFAULT_SIZE_SCALE;
  return Math.min(3, Math.max(0.35, raw));
})();

const effectiveSizePx = Math.max(1, Math.round(sizePx * sizeScale));

const sizeMode = (() => {
  const m = props.sizeMode;
  if (m === 'responsive') return 'responsive' as const;
  if (m === 'container') return 'container' as const;
  return 'fixed' as const;
})();

const containerCqw = (() => {
  if (sizeMode !== 'container') return 0;
  const n = Number(props.containerCqw);
  if (!Number.isFinite(n) || n <= 0) return 10;
  return Math.min(35, Math.max(2.5, n));
})();

const responsiveMaxVmin = (() => {
  const n = Number(props.responsiveMaxVmin);
  if (!Number.isFinite(n) || n <= 0) return 0;
  return Math.min(72, Math.max(8, n));
})();

const responsiveMaxCqmin = (() => {
  const n = Number(props.responsiveMaxCqmin);
  if (!Number.isFinite(n) || n <= 0) return 0;
  return Math.min(80, Math.max(6, n));
})();

const responsiveMaxCqw = (() => {
  const n = Number(props.responsiveMaxCqw);
  if (!Number.isFinite(n) || n <= 0) return 0;
  return Math.min(40, Math.max(4, n));
})();

const responsiveClampMaxPx = (() => {
  const n = Number(props.responsiveClampMaxPx);
  if (!Number.isFinite(n) || n <= 0) return 0;
  // Sub-40 caps are allowed (previously floored at 40, which made small values ineffective).
  return Math.min(200, Math.max(12, Math.round(n)));
})();

const color = props.color ?? '#111';
const durationSec = Number(props.duration);
const duration =
  Number.isFinite(durationSec) && durationSec > 0 ? durationSec : 2.6;
const className = props.class ?? '';
const direction = props.direction === 'down' ? 'down' : 'up';

const opacity = (() => {
  const n = Number(props.opacity);
  return Number.isFinite(n) ? Math.min(1, Math.max(0, n)) : 1;
})();

const texturePatternId = `animated-arrow-texture-${crypto.randomUUID()}`;
const textureUrl = (props.textureUrl ?? '').trim();
const hasTexture = textureUrl.length > 0;
const textureBrightness = (() => {
  const n = Number(props.textureBrightness);
  if (!Number.isFinite(n)) return 1;
  return Math.min(2, Math.max(0.2, n));
})();
const textureContrast = (() => {
  const n = Number(props.textureContrast);
  if (!Number.isFinite(n)) return 1;
  return Math.min(2.5, Math.max(0.2, n));
})();
const textureZoom = (() => {
  const n = Number(props.textureZoom);
  if (!Number.isFinite(n)) return 1;
  return Math.min(4, Math.max(0.25, n));
})();
const textureW = VIEWBOX_W / textureZoom;
const textureH = VIEWBOX_H / textureZoom;
const textureX = (VIEWBOX_W - textureW) / 2;
const textureY = (VIEWBOX_H - textureH) / 2;

function containerSvgStyle(cqw: number): string {
  return `width: ${cqw.toFixed(3)}cqw; height: auto; aspect-ratio: 220 / 170`;
}

function responsiveSvgStyle(
  scale: number,
  clampMaxPx: number,
  maxVmin: number,
  maxCqmin: number,
  maxCqw: number,
): string {
  const { minRem, baseRem, vw, minSizeFactor } = RESPONSIVE_WIDTH;
  const mr = (minRem * scale).toFixed(4);
  const br = (baseRem * scale).toFixed(4);
  const vwS = (vw * scale).toFixed(4);
  const clamped = [
    'clamp(',
    `min(${mr}rem, calc(var(--arrow-size-px) * ${minSizeFactor} * 1px)), `,
    `min(${br}rem + ${vwS}vw, calc(var(--arrow-size-px) * 1px)), `,
    'calc(var(--arrow-size-px) * 1px))',
  ].join('');
  const parts: string[] = [clamped];
  if (clampMaxPx > 0) parts.push(`${clampMaxPx}px`);
  if (maxVmin > 0) parts.push(`${maxVmin.toFixed(2)}vmin`);
  if (maxCqmin > 0) parts.push(`${maxCqmin.toFixed(2)}cqmin`);
  if (maxCqw > 0) parts.push(`${maxCqw.toFixed(2)}cqw`);
  const width = parts.length > 1 ? `min(${parts.join(', ')})` : clamped;
  return `width: ${width}; height: auto; aspect-ratio: 220 / 170`;
}

const rootStyle = [
  `--arrow-size-px: ${effectiveSizePx}`,
  `--arrow-shape-opacity: ${opacity}`,
  `--arrow-color: ${color}`,
  `--arrow-duration: ${duration}s`,
].join('; ');

const dirClass = direction === 'down' ? 'animated-arrow--down' : '';
const fixedHeight = (effectiveSizePx * VIEWBOX_H) / VIEWBOX_W;
---

<span
  class:list={['animated-arrow-root', dirClass]}
  style={rootStyle}
  aria-hidden="true"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox={`0 0 ${VIEWBOX_W} ${VIEWBOX_H}`}
    width={sizeMode === 'fixed' ? effectiveSizePx : undefined}
    height={sizeMode === 'fixed' ? fixedHeight : undefined}
    class:list={['animated-arrow', className]}
    style={sizeMode === 'responsive'
      ? responsiveSvgStyle(
          sizeScale,
          responsiveClampMaxPx,
          responsiveMaxVmin,
          responsiveMaxCqmin,
          responsiveMaxCqw,
        )
      : sizeMode === 'container'
        ? containerSvgStyle(containerCqw)
        : undefined}
    aria-hidden="true"
  >
    <defs>
      {hasTexture && (
        <pattern
          id={texturePatternId}
          patternUnits="userSpaceOnUse"
          x="0"
          y="0"
          width={VIEWBOX_W}
          height={VIEWBOX_H}
        >
          <image
            href={textureUrl}
            x={textureX}
            y={textureY}
            width={textureW}
            height={textureH}
            preserveAspectRatio="xMidYMid slice"
            style={`filter: brightness(${textureBrightness}) contrast(${textureContrast});`}
          />
        </pattern>
      )}
    </defs>
    <g class="arrow-grain-group">
      <polygon
        class="seg s1"
        style={hasTexture ? `fill: url(#${texturePatternId})` : undefined}
        points="30,148.564 190,148.564 180.762,132.564 39.238,132.564"
      ></polygon>
      <polygon
        class="seg s2"
        style={hasTexture ? `fill: url(#${texturePatternId})` : undefined}
        points="43.856,124.564 176.144,124.564 166.906,108.564 53.094,108.564"
      ></polygon>
      <polygon
        class="seg s3"
        style={hasTexture ? `fill: url(#${texturePatternId})` : undefined}
        points="57.713,100.564 162.287,100.564 153.050,84.564 66.950,84.564"
      ></polygon>
      <polygon
        class="seg s4"
        style={hasTexture ? `fill: url(#${texturePatternId})` : undefined}
        points="71.569,76.564 148.431,76.564 139.193,60.564 80.807,60.564"
      ></polygon>
      <polygon
        class="seg s5"
        style={hasTexture ? `fill: url(#${texturePatternId})` : undefined}
        points="85.426,52.564 134.574,52.564 125.337,36.564 94.663,36.564"
      ></polygon>
      <polygon
        class="seg s6"
        style={hasTexture ? `fill: url(#${texturePatternId})` : undefined}
        points="99.282,28.564 120.718,28.564 110,10"
      ></polygon>
    </g>
  </svg>
</span>
