---
/**
 * Segmented chevron with optional SVG grain (feTurbulence + soft-light). The root `<span>` is not
 * faded so #111 panels behind the arrow (e.g. /why) don’t wash out.
 *
 * Sizing: `size` = nominal width in px. `sizeMode="fixed"` — exact px; `responsive` — clamp(rem+vw, max=size).
 * `sizeScale` multiplies both. See RESPONSIVE_WIDTH for responsive clamp coefficients.
 */
// eslint-disable-next-line no-unused-vars, @typescript-eslint/no-unused-vars -- Astro `Props` → `Astro.props`
interface Props {
  size?: number;
  sizeMode?: 'fixed' | 'responsive';
  /** Multiplies `size` and responsive rem/vw terms (default 1). */
  sizeScale?: number;
  color?: string;
  duration?: number;
  class?: string;
  direction?: 'up' | 'down';
  opacity?: number;
  grainOpacity?: number;
  /** Noise “tile” size in viewBox units; ~180–260 = visible grain, tiny values flatten. */
  grainSize?: number;
}

const VIEWBOX_W = 220;
const VIEWBOX_H = 170;

const RESPONSIVE_WIDTH = {
  minRem: 2.55,
  baseRem: 2.15,
  vw: 1.05,
  /** Lower clamp vs `size`: min(rem floor, size * this). */
  minSizeFactor: 0.72,
} as const;

/** Default `sizeScale`; override per `<AnimatedArrow sizeScale={…} />`. */
const DEFAULT_SIZE_SCALE = 1;

const props = Astro.props;

const sizePx = (() => {
  const n = Number(props.size);
  return Number.isFinite(n) && n > 0 ? n : 120;
})();

const sizeScale = (() => {
  const raw = Number(props.sizeScale ?? DEFAULT_SIZE_SCALE);
  if (!Number.isFinite(raw) || raw <= 0) return DEFAULT_SIZE_SCALE;
  return Math.min(3, Math.max(0.35, raw));
})();

const effectiveSizePx = Math.max(1, Math.round(sizePx * sizeScale));

const sizeMode = props.sizeMode === 'responsive' ? 'responsive' : 'fixed';

const color = props.color ?? '#111';
const durationSec = Number(props.duration);
const duration =
  Number.isFinite(durationSec) && durationSec > 0 ? durationSec : 2.6;
const className = props.class ?? '';
const direction = props.direction === 'down' ? 'down' : 'up';

const opacity = (() => {
  const n = Number(props.opacity);
  return Number.isFinite(n) ? Math.min(1, Math.max(0, n)) : 1;
})();

const grainOpacity = (() => {
  const n = Number(props.grainOpacity);
  return Number.isFinite(n) ? Math.min(1, Math.max(0, n)) : 0.2;
})();

const grainSize = (() => {
  const n = Number(props.grainSize);
  return Number.isFinite(n) && n > 0 ? n : 220;
})();

// Slightly stronger than 1:1 with opacity — soft-light on pale fills needs more contrast.
const grainNoiseSlope = Math.min(1, grainOpacity * 1.35).toFixed(4);
const rawGrainFreq = (VIEWBOX_W / grainSize) * 0.85;
const grainBaseFreq = Math.min(1.25, Math.max(0.42, rawGrainFreq)).toFixed(4);
const grainFilterId = `animated-arrow-grain-${crypto.randomUUID()}`;

function responsiveSvgStyle(scale: number): string {
  const { minRem, baseRem, vw, minSizeFactor } = RESPONSIVE_WIDTH;
  const mr = (minRem * scale).toFixed(4);
  const br = (baseRem * scale).toFixed(4);
  const vwS = (vw * scale).toFixed(4);
  return [
    'width: clamp(',
    `min(${mr}rem, calc(var(--arrow-size-px) * ${minSizeFactor} * 1px)), `,
    `min(${br}rem + ${vwS}vw, calc(var(--arrow-size-px) * 1px)), `,
    'calc(var(--arrow-size-px) * 1px)); height: auto; aspect-ratio: 220 / 170',
  ].join('');
}

const rootStyle = [
  `--arrow-size-px: ${effectiveSizePx}`,
  `--arrow-shape-opacity: ${opacity}`,
  `--arrow-color: ${color}`,
  `--arrow-duration: ${duration}s`,
].join('; ');

const dirClass = direction === 'down' ? 'animated-arrow--down' : '';
const fixedHeight = (effectiveSizePx * VIEWBOX_H) / VIEWBOX_W;
---

<span
  class:list={['animated-arrow-root', dirClass]}
  style={rootStyle}
  aria-hidden="true"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox={`0 0 ${VIEWBOX_W} ${VIEWBOX_H}`}
    width={sizeMode === 'fixed' ? effectiveSizePx : undefined}
    height={sizeMode === 'fixed' ? fixedHeight : undefined}
    class:list={['animated-arrow', className]}
    style={sizeMode === 'responsive'
      ? responsiveSvgStyle(sizeScale)
      : undefined}
    aria-hidden="true"
  >
    <defs>
      <filter
        id={grainFilterId}
        color-interpolation-filters="sRGB"
        x="-35%"
        y="-35%"
        width="170%"
        height="170%"
      >
        <feTurbulence
          type="fractalNoise"
          baseFrequency={grainBaseFreq}
          numOctaves="3"
          stitchTiles="stitch"
          result="turb"></feTurbulence>
        <feColorMatrix in="turb" type="saturate" values="0" result="turbGray"
        ></feColorMatrix>
        <feComponentTransfer in="turbGray" result="turbA">
          <feFuncA type="linear" slope={grainNoiseSlope} intercept="0"
          ></feFuncA>
        </feComponentTransfer>
        <feComposite
          in="turbA"
          in2="SourceGraphic"
          operator="in"
          result="noiseClip"></feComposite>
        <feBlend in="SourceGraphic" in2="noiseClip" mode="soft-light"></feBlend>
      </filter>
    </defs>
    <g class="arrow-grain-group" filter={`url(#${grainFilterId})`}>
      <polygon
        class="seg s1"
        points="30,148.564 190,148.564 180.762,132.564 39.238,132.564"
      ></polygon>
      <polygon
        class="seg s2"
        points="43.856,124.564 176.144,124.564 166.906,108.564 53.094,108.564"
      ></polygon>
      <polygon
        class="seg s3"
        points="57.713,100.564 162.287,100.564 153.050,84.564 66.950,84.564"
      ></polygon>
      <polygon
        class="seg s4"
        points="71.569,76.564 148.431,76.564 139.193,60.564 80.807,60.564"
      ></polygon>
      <polygon
        class="seg s5"
        points="85.426,52.564 134.574,52.564 125.337,36.564 94.663,36.564"
      ></polygon>
      <polygon class="seg s6" points="99.282,28.564 120.718,28.564 110,10"
      ></polygon>
    </g>
  </svg>
</span>

<style>
  .animated-arrow-root {
    position: relative;
    display: inline-block;
    line-height: 0;
    vertical-align: middle;
  }

  .animated-arrow-root .animated-arrow {
    display: block;
    opacity: var(--arrow-shape-opacity, 1);
  }

  .animated-arrow--down {
    transform: rotate(180deg);
    transform-origin: center center;
  }

  .animated-arrow .seg {
    fill: var(--arrow-color);
    opacity: 0;
    animation-duration: var(--arrow-duration);
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .animated-arrow .s1 {
    animation-name: seg1;
  }
  .animated-arrow .s2 {
    animation-name: seg2;
  }
  .animated-arrow .s3 {
    animation-name: seg3;
  }
  .animated-arrow .s4 {
    animation-name: seg4;
  }
  .animated-arrow .s5 {
    animation-name: seg5;
  }
  .animated-arrow .s6 {
    animation-name: seg6;
  }

  @keyframes seg1 {
    0%,
    8% {
      opacity: 0;
    }
    8.01%,
    58% {
      opacity: 1;
    }
    58.01%,
    100% {
      opacity: 0;
    }
  }

  @keyframes seg2 {
    0%,
    16% {
      opacity: 0;
    }
    16.01%,
    66% {
      opacity: 1;
    }
    66.01%,
    100% {
      opacity: 0;
    }
  }

  @keyframes seg3 {
    0%,
    24% {
      opacity: 0;
    }
    24.01%,
    74% {
      opacity: 1;
    }
    74.01%,
    100% {
      opacity: 0;
    }
  }

  @keyframes seg4 {
    0%,
    32% {
      opacity: 0;
    }
    32.01%,
    82% {
      opacity: 1;
    }
    82.01%,
    100% {
      opacity: 0;
    }
  }

  @keyframes seg5 {
    0%,
    40% {
      opacity: 0;
    }
    40.01%,
    90% {
      opacity: 1;
    }
    90.01%,
    100% {
      opacity: 0;
    }
  }

  @keyframes seg6 {
    0%,
    48% {
      opacity: 0;
    }
    48.01%,
    98% {
      opacity: 1;
    }
    98.01%,
    100% {
      opacity: 0;
    }
  }
</style>
